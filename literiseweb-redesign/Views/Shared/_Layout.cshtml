<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - LiteRise</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
</head>
<body>

    <!-- Theme Toggle -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <svg class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5" stroke-width="2"></circle>
            <line x1="12" y1="1" x2="12" y2="3" stroke-width="2"></line>
            <line x1="12" y1="21" x2="12" y2="23" stroke-width="2"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke-width="2"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke-width="2"></line>
            <line x1="1" y1="12" x2="3" y2="12" stroke-width="2"></line>
            <line x1="21" y1="12" x2="23" y2="12" stroke-width="2"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke-width="2"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke-width="2"></line>
        </svg>
        <svg class="moon-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
    </button>

    <!-- ══ TOP BAR ══════════════════════════════════════════════ -->
    <div class="TopBar">
        <div class="topbar-left">
            <!-- Desktop sidebar toggle -->
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
            <!-- Mobile toggle -->
            <button class="sidebar-toggle mobile-toggle" id="mobileSidebarToggle" aria-label="Open menu">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>

            <a href="@Url.Action("Index", "Dashboard")" class="topbar-brand">
                LiteRise
            </a>
        </div>

        <div class="topbar-right">
            <!-- Notifications -->
            <div class="dropdown-container">
                <button class="topbar-icon-btn" id="notificationsToggle"
                        aria-label="Notifications" aria-expanded="false">
                    <span class="glyphicon glyphicon-bell"></span>
                    <span class="notification-badge">5</span>
                </button>
                <div class="notifications-panel" id="notificationsPanel">
                    <div class="notifications-header">
                        <h3>Notifications</h3>
                    </div>
                    <div class="notifications-list">
                        <a href="#" class="notification-item unread">
                            <div class="notification-icon success">
                                <span class="glyphicon glyphicon-ok-circle"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">
                                    <strong>John Smith</strong> submitted Final Project Report
                                </div>
                                <div class="notification-time">2 hours ago</div>
                            </div>
                        </a>
                        <a href="#" class="notification-item unread">
                            <div class="notification-icon warning">
                                <span class="glyphicon glyphicon-exclamation-sign"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">
                                    <strong>Sarah Johnson</strong> requested grade review for Quiz #5
                                </div>
                                <div class="notification-time">5 hours ago</div>
                            </div>
                        </a>
                        <a href="#" class="notification-item unread">
                            <div class="notification-icon info">
                                <span class="glyphicon glyphicon-info-sign"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">
                                    New student <strong>Mike Davis</strong> enrolled
                                </div>
                                <div class="notification-time">1 day ago</div>
                            </div>
                        </a>
                        <a href="#" class="notification-item">
                            <div class="notification-icon success">
                                <span class="glyphicon glyphicon-upload"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">Database backup completed</div>
                                <div class="notification-time">2 days ago</div>
                            </div>
                        </a>
                        <a href="#" class="notification-item">
                            <div class="notification-icon error">
                                <span class="glyphicon glyphicon-alert"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">System maintenance scheduled</div>
                                <div class="notification-time">3 days ago</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Settings -->
            <div class="dropdown-container">
                <button class="topbar-icon-btn" id="settingsToggle"
                        aria-label="Settings" aria-expanded="false">
                    <span class="glyphicon glyphicon-cog"></span>
                </button>
                <div class="dropdown-menu" id="settingsDropdown">
                    <a href="@Url.Action("Account", "Settings")">
                        <span class="glyphicon glyphicon-user"></span> Account
                    </a>
                    <a href="@Url.Action("Index", "Settings")">
                        <span class="glyphicon glyphicon-cog"></span> Settings
                    </a>
                    <div class="dropdown-divider"></div>
                    <a href="javascript:void(0);" id="logoutLink">
                        <span class="glyphicon glyphicon-log-out"></span> Log out
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════ -->
    <div class="Sidebar" id="sidebar">
        <div class="sidebar-content">
            <nav class="sidebar-nav">
                <a href="@Url.Action("Index", "Dashboard")"
                   class="sidebar-nav-item" data-page="Dashboard" title="Dashboard">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-dashboard"></span>
                    </div>
                    <span class="sidebar-text">Dashboard</span>
                </a>

                <a href="@Url.Action("Index", "Student")"
                   class="sidebar-nav-item" data-page="Students" title="Students">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-education"></span>
                    </div>
                    <span class="sidebar-text">Students</span>
                </a>

                <a href="@Url.Action("Index", "Schools")"
                   class="sidebar-nav-item" data-page="Schools" title="Schools">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-home"></span>
                    </div>
                    <span class="sidebar-text">Schools</span>
                </a>

                <a href="@Url.Action("Index", "Masterfile")"
                   class="sidebar-nav-item" data-page="Masterfile" title="Masterfile">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-folder-open"></span>
                    </div>
                    <span class="sidebar-text">Masterfile</span>
                </a>

                <a href="@Url.Action("Index", "Analytics")"
                   class="sidebar-nav-item" data-page="Analytics" title="Analytics">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-stats"></span>
                    </div>
                    <span class="sidebar-text">Analytics</span>
                </a>

                <a href="@Url.Action("Index", "Administration")"
                   class="sidebar-nav-item" data-page="Administration" title="Administration">
                    <div class="sidebar-icon">
                        <span class="glyphicon glyphicon-cog"></span>
                    </div>
                    <span class="sidebar-text">Administration</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <a href="@Url.Action("Account", "Settings")" class="sidebar-profile">
                    <div class="profile-avatar">JD</div>
                    <div class="profile-info">
                        <div class="profile-name">John Doe</div>
                        <div class="profile-email">john@literise.com</div>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════ -->
    <div class="Main-Container">
        <div class="Container-Body">
            @RenderBody()
        </div>
    </div>

    <!-- ══ LOGOUT MODAL ═════════════════════════════════════════ -->
    <div id="logoutModal" class="logout-modal">
        <div class="logout-modal-content">
            <button class="logout-modal-close" id="logoutModalClose"
                    aria-label="Close modal">&times;</button>
            <div class="logout-modal-icon">
                <svg viewBox="0 0 100 100" fill="none">
                    <circle cx="50" cy="50" r="45" fill="#FEE2E2" />
                    <path d="M50 30C38.95 30 30 38.95 30 50C30 61.05 38.95 70 50 70C61.05 70 70 61.05 70 50C70 38.95 61.05 30 50 30ZM54 55H46V47H54V55ZM54 43H46V35H54V43Z"
                          fill="#DC2626" />
                </svg>
            </div>
            <h2>Log Out</h2>
            <p>Are you sure you want to log out?</p>
            <div class="logout-modal-buttons">
                <button class="btn-logout-cancel" id="btnLogoutCancel">Cancel</button>
                <button class="btn-logout-confirm" id="btnLogoutConfirm">Yes, Log Out</button>
            </div>
        </div>
    </div>

    @RenderSection("modals", required: false)

    <!-- Scripts -->
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    @RenderSection("scripts", required: false)
    <script src="~/Scripts/layout.js"></script>
</body>
</html>
