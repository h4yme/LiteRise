<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Purple Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_purple"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="44dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Progress"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/visby_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Track your learning journey"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:fontFamily="@font/visby_regular"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- White Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_top_rounded"
                android:layout_marginTop="-24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- XP Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_star"
                                app:tint="#FFD700"
                                android:contentDescription="XP"/>

                            <TextView
                                android:id="@+id/tvStatXP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2D3436"
                                android:fontFamily="@font/visby_bold"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total XP"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Streak Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_fire"
                                app:tint="#FF6B35"
                                android:contentDescription="Streak"/>

                            <TextView
                                android:id="@+id/tvStatStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2D3436"
                                android:fontFamily="@font/visby_bold"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Day Streak"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Lessons Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="#10B981"
                                android:contentDescription="Lessons"/>

                            <TextView
                                android:id="@+id/tvStatLessons"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2D3436"
                                android:fontFamily="@font/visby_bold"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lessons Done"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Skills Breakdown -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skills Breakdown"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/visby_bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Phonics Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_orange"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Phonics &amp; Word Study"
                            android:textSize="13sp"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_medium"/>

                        <TextView
                            android:id="@+id/tvScorePhonics"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressPhonics"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressBackgroundTint="#F0EFFE"
                        android:progressTint="#FF6B35"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

                <!-- Vocabulary Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_teal"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vocabulary &amp; Word Knowledge"
                            android:textSize="13sp"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_medium"/>

                        <TextView
                            android:id="@+id/tvScoreVocab"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressVocab"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressBackgroundTint="#F0EFFE"
                        android:progressTint="#4ECDC4"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

                <!-- Grammar Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_purple"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Grammar Awareness"
                            android:textSize="13sp"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_medium"/>

                        <TextView
                            android:id="@+id/tvScoreGrammar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressGrammar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressBackgroundTint="#F0EFFE"
                        android:progressTint="#A770EF"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

                <!-- Comprehension Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_yellow"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Comprehending Text"
                            android:textSize="13sp"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_medium"/>

                        <TextView
                            android:id="@+id/tvScoreComprehension"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressComprehension"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressBackgroundTint="#F0EFFE"
                        android:progressTint="#FFD93D"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

                <!-- Writing Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_dot_blue"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Creating &amp; Composing"
                            android:textSize="13sp"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_medium"/>

                        <TextView
                            android:id="@+id/tvScoreWriting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:fontFamily="@font/visby_bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressWriting"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressBackgroundTint="#F0EFFE"
                        android:progressTint="#667EEA"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

                <!-- View Full Report Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewFullReport"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="View Full Comparison Report"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/visby_bold"
                    app:backgroundTint="#7C3AED"
                    app:cornerRadius="24dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Bottom spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Bottom Navigation -->
    <include
        android:id="@+id/customBottomNav"
        layout="@layout/custom_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
