<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2D1B6B">

    <!-- Background Lottie sparkles (fills upper portion above card) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/contentCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:lottie_rawRes="@raw/placement_intro_bg_lottie"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_speed="0.7" />

    <!-- Skip Button (Top Right) -->
    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/visby_medium"
        android:padding="10dp"
        android:text="Skip"
        android:textColor="#80FFFFFF"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Leo Character Container (floats above card, centered) -->
    <FrameLayout
        android:id="@+id/flLeoContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/contentCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.82">

        <!-- Golden glow circle behind Leo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/leo_glow_placement" />

        <!-- Leo character -->
        <ImageView
            android:id="@+id/ivLeo"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center"
            android:src="@drawable/leo_happy"
            android:scaleType="centerInside" />

    </FrameLayout>

    <!-- Bottom Content Card -->
    <LinearLayout
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_walkthrough_card"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- "Leo says..." orange badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_orange"
            android:fontFamily="@font/visby_bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="Leo says..."
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="14dp" />

        <!-- Step Title -->
        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/visby_bold"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="10dp" />

        <!-- Step Description -->
        <TextView
            android:id="@+id/tvStepDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/visby_regular"
            android:textColor="#CCB8FF"
            android:textSize="15sp"
            android:lineSpacingExtra="5dp"
            android:layout_marginBottom="28dp" />

        <!-- Progress Dot Indicators -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="32dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/indicator_dot_active" />

            <View
                android:id="@+id/dot2"
                android:layout_width="10dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/indicator_dot_placement_inactive" />

            <View
                android:id="@+id/dot3"
                android:layout_width="10dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/indicator_dot_placement_inactive" />

            <View
                android:id="@+id/dot4"
                android:layout_width="10dp"
                android:layout_height="8dp"
                android:background="@drawable/indicator_dot_placement_inactive" />

        </LinearLayout>

        <!-- Next / Start Test Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/visby_bold"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            app:backgroundTint="#FF8C42"
            app:cornerRadius="20dp"
            app:elevation="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>