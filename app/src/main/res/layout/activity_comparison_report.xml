<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#7C3AED"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Progress Report"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See how much you've grown!"
                android:textColor="#DDD6FE"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginStart="48dp" />
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBarLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="visible" />

        <!-- Content (hidden while loading) -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- No post-assessment notice -->
            <LinearLayout
                android:id="@+id/layoutNoPostAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_modern"
                android:padding="20dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="40sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete all 65 lessons to unlock your full growth report!"
                    android:textSize="15sp"
                    android:textColor="#374151"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvProgressHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 65 lessons completed"
                    android:textSize="13sp"
                    android:textColor="#7C3AED"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Pre-Assessment Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pre-Assessment"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:id="@+id/cardPre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_modern"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Theta Score"
                        android:textSize="14sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tvPreTheta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#7C3AED" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginVertical="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPreLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#374151" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accuracy"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPreAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#374151" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPreDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textColor="#374151" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Post-Assessment Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post-Assessment"
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/cardPost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_modern"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Theta Score"
                        android:textSize="14sp"
                        android:textColor="#374151" />

                    <TextView
                        android:id="@+id/tvPostTheta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not taken yet"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#9CA3AF" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginVertical="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPostLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#374151" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accuracy"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPostAccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#374151" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date"
                            android:textSize="12sp"
                            android:textColor="#9CA3AF" />

                        <TextView
                            android:id="@+id/tvPostDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:textColor="#374151" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Growth Summary Card (only shown when post-assessment done) -->
            <LinearLayout
                android:id="@+id/cardGrowth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_modern"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Growth"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="12dp" />

                <!-- Theta Growth Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ability Score"
                        android:textSize="14sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvThetaGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0.00"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#059669" />
                </LinearLayout>

                <!-- Level Growth Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Level"
                        android:textSize="14sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvLevelGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#059669" />
                </LinearLayout>

                <!-- Accuracy Growth Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accuracy"
                        android:textSize="14sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:id="@+id/tvAccuracyGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0.00%"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#059669" />
                </LinearLayout>

                <!-- Growth Status Badge -->
                <TextView
                    android:id="@+id/tvComparisonStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMPROVED"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="#059669"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Category Scores Card -->
            <LinearLayout
                android:id="@+id/cardCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_modern"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category Scores (Pre-Assessment)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="12dp" />

                <!-- Phonics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phonics"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <ProgressBar
                        android:id="@+id/pbPhonics"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="2"
                        android:max="100"
                        android:progressTint="#FF6B6B"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:id="@+id/tvPhonicsScore"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Vocabulary -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vocabulary"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <ProgressBar
                        android:id="@+id/pbVocabulary"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="2"
                        android:max="100"
                        android:progressTint="#4ECDC4"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:id="@+id/tvVocabularyScore"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Grammar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Grammar"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <ProgressBar
                        android:id="@+id/pbGrammar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="2"
                        android:max="100"
                        android:progressTint="#A770EF"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:id="@+id/tvGrammarScore"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Comprehension -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Comprehension"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <ProgressBar
                        android:id="@+id/pbComprehension"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="2"
                        android:max="100"
                        android:progressTint="#FFD93D"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:id="@+id/tvComprehensionScore"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Creating -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Creating Text"
                        android:textSize="13sp"
                        android:textColor="#6B7280" />

                    <ProgressBar
                        android:id="@+id/pbCreating"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="2"
                        android:max="100"
                        android:progressTint="#667EEA"
                        android:layout_marginHorizontal="8dp" />

                    <TextView
                        android:id="@+id/tvCreatingScore"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
