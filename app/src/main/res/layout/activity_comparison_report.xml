<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_purple"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Top row: back + title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/ic_arrow_back"
                        android:padding="8dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:contentDescription="Back"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Progress Report"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:fontFamily="@font/visby_bold"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See how much you've grown!"
                    android:textColor="#DDD6FE"
                    android:textSize="14sp"
                    android:fontFamily="@font/visby_regular"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="50dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBarLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:visibility="visible" />

        <!-- Content (hidden while loading) -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp"
            android:visibility="gone">

            <!-- No post-assessment notice -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutNoPostAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊"
                        android:textSize="38sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete all 65 lessons to unlock your full growth report!"
                        android:textSize="14sp"
                        android:textColor="#374151"
                        android:textAlignment="center"
                        android:fontFamily="@font/visby_regular"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvProgressHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 65 lessons completed"
                        android:textSize="13sp"
                        android:textColor="#7C3AED"
                        android:fontFamily="@font/visby_bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Theta Comparison Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_gradient_purple_blue"
                    android:padding="20dp">

                    <!-- Title row -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Ability Score"
                        android:textSize="13sp"
                        android:textColor="#DDD6FE"
                        android:fontFamily="@font/visby_bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="16dp" />

                    <!-- PRE vs POST row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Pre theta block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PRE"
                                android:textSize="11sp"
                                android:textColor="#C4B5FD"
                                android:fontFamily="@font/visby_bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvPreTheta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="34sp"
                                android:fontFamily="@font/visby_bold"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tvPreLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="13sp"
                                android:textColor="#DDD6FE"
                                android:fontFamily="@font/visby_bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Arrow divider -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="26sp"
                            android:textColor="#C4B5FD"
                            android:layout_marginHorizontal="8dp" />

                        <!-- Post theta block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="POST"
                                android:textSize="11sp"
                                android:textColor="#C4B5FD"
                                android:fontFamily="@font/visby_bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvPostTheta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="34sp"
                                android:fontFamily="@font/visby_bold"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tvPostLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not taken yet"
                                android:textSize="13sp"
                                android:textColor="#DDD6FE"
                                android:fontFamily="@font/visby_bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#30FFFFFF"
                        android:layout_marginVertical="14dp" />

                    <!-- Stats row (accuracy + date) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Pre stats -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Accuracy"
                                    android:textSize="11sp"
                                    android:textColor="#C4B5FD"
                                    android:fontFamily="@font/visby_regular" />

                                <TextView
                                    android:id="@+id/tvPreAccuracy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="14sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/visby_bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Date"
                                    android:textSize="11sp"
                                    android:textColor="#C4B5FD"
                                    android:fontFamily="@font/visby_regular" />

                                <TextView
                                    android:id="@+id/tvPreDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="12sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/visby_bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#30FFFFFF"
                            android:layout_gravity="center_vertical" />

                        <!-- Post stats -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Accuracy"
                                    android:textSize="11sp"
                                    android:textColor="#C4B5FD"
                                    android:fontFamily="@font/visby_regular" />

                                <TextView
                                    android:id="@+id/tvPostAccuracy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="14sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/visby_bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Date"
                                    android:textSize="11sp"
                                    android:textColor="#C4B5FD"
                                    android:fontFamily="@font/visby_regular" />

                                <TextView
                                    android:id="@+id/tvPostDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="12sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/visby_bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Growth Summary Card (only shown when post-assessment done) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrowth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🚀 Your Growth"
                            android:textSize="16sp"
                            android:fontFamily="@font/visby_bold"
                            android:textColor="#1F2937" />

                        <TextView
                            android:id="@+id/tvComparisonStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IMPROVED"
                            android:textSize="11sp"
                            android:fontFamily="@font/visby_bold"
                            android:textColor="#FFFFFF"
                            android:background="#059669"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp" />
                    </LinearLayout>

                    <!-- Growth stat tiles -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Ability growth tile -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ability"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular" />

                            <TextView
                                android:id="@+id/tvThetaGrowth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+0.00"
                                android:textSize="20sp"
                                android:fontFamily="@font/visby_bold"
                                android:textColor="#059669"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Level growth tile -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:layout_marginHorizontal="3dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Level"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular" />

                            <TextView
                                android:id="@+id/tvLevelGrowth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+0"
                                android:textSize="20sp"
                                android:fontFamily="@font/visby_bold"
                                android:textColor="#059669"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Accuracy growth tile -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_card"
                            android:padding="12dp"
                            android:gravity="center"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Accuracy"
                                android:textSize="11sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_regular" />

                            <TextView
                                android:id="@+id/tvAccuracyGrowth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+0%"
                                android:textSize="20sp"
                                android:fontFamily="@font/visby_bold"
                                android:textColor="#059669"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Category Scores Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚 Skill Breakdown"
                        android:textSize="16sp"
                        android:fontFamily="@font/visby_bold"
                        android:textColor="#1F2937"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pre-Assessment scores"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:fontFamily="@font/visby_regular"
                        android:layout_marginBottom="16dp" />

                    <!-- Phonics -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🔤 Phonics"
                                android:textSize="13sp"
                                android:textColor="#374151"
                                android:fontFamily="@font/visby_bold" />

                            <TextView
                                android:id="@+id/tvPhonicsScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="13sp"
                                android:textColor="#7C3AED"
                                android:fontFamily="@font/visby_bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbPhonics"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progressTint="#FF6B6B"
                            android:progressBackgroundTint="#F3F4F6" />
                    </LinearLayout>

                    <!-- Vocabulary -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📖 Vocabulary"
                                android:textSize="13sp"
                                android:textColor="#374151"
                                android:fontFamily="@font/visby_bold" />

                            <TextView
                                android:id="@+id/tvVocabularyScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="13sp"
                                android:textColor="#7C3AED"
                                android:fontFamily="@font/visby_bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbVocabulary"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progressTint="#4ECDC4"
                            android:progressBackgroundTint="#F3F4F6" />
                    </LinearLayout>

                    <!-- Grammar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="✏️ Grammar"
                                android:textSize="13sp"
                                android:textColor="#374151"
                                android:fontFamily="@font/visby_bold" />

                            <TextView
                                android:id="@+id/tvGrammarScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="13sp"
                                android:textColor="#7C3AED"
                                android:fontFamily="@font/visby_bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbGrammar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progressTint="#A770EF"
                            android:progressBackgroundTint="#F3F4F6" />
                    </LinearLayout>

                    <!-- Comprehension -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="💡 Comprehension"
                                android:textSize="13sp"
                                android:textColor="#374151"
                                android:fontFamily="@font/visby_bold" />

                            <TextView
                                android:id="@+id/tvComprehensionScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="13sp"
                                android:textColor="#7C3AED"
                                android:fontFamily="@font/visby_bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbComprehension"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progressTint="#FFD93D"
                            android:progressBackgroundTint="#F3F4F6" />
                    </LinearLayout>

                    <!-- Creating Text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🖊️ Creating Text"
                                android:textSize="13sp"
                                android:textColor="#374151"
                                android:fontFamily="@font/visby_bold" />

                            <TextView
                                android:id="@+id/tvCreatingScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="13sp"
                                android:textColor="#7C3AED"
                                android:fontFamily="@font/visby_bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbCreating"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
