<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE">

    <!-- Main Content — scrolls behind floating nav -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer column — NO horizontal padding (header must be full-width) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════════════
                 HERO HEADER  — purple gradient, full width
                 ═══════════════════════════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_purple"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="44dp">

                <!-- Lottie sparkle decoration (top-right corner) -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieHeaderSparkle"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="end|top"
                    android:layout_marginEnd="30dp"
                    app:lottie_rawRes="@raw/lottie_sparkle_stars"
                    app:lottie_loop="true"
                    app:lottie_autoPlay="true"
                    android:alpha="0.4"/>

                <!-- Header content column -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- TOP ROW: greeting + settings icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Greeting text -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvWelcome"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello, Student!"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/visby_bold"/>

                            <TextView
                                android:id="@+id/tvMotivation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ready to learn today?"
                                android:textSize="13sp"
                                android:textColor="#CCFFFFFF"
                                android:fontFamily="@font/visby_regular"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- Settings icon -->
                        <ImageView
                            android:id="@+id/ivSettings"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:src="@drawable/ic_settings"
                            android:background="@drawable/icon_circle_white"
                            android:padding="9dp"
                            app:tint="#FFFFFF"
                            android:contentDescription="Settings"/>
                    </LinearLayout>

                    <!-- MIDDLE ROW: stats pills + Leo mascot -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">

                        <!-- Stats pills column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Row 1: XP + Streak -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <!-- XP pill -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_semi_white_pill"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="7dp"
                                    android:paddingBottom="7dp"
                                    android:layout_marginEnd="8dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_star"
                                        android:layout_marginEnd="5dp"
                                        app:tint="#FFD700"
                                        android:contentDescription="XP"/>

                                    <TextView
                                        android:id="@+id/tvHeaderXP"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 XP"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#FFFFFF"
                                        android:fontFamily="@font/visby_bold"/>
                                </LinearLayout>

                                <!-- Streak pill -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:background="@drawable/bg_semi_white_pill"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="7dp"
                                    android:paddingBottom="7dp">

                                    <ImageView
                                        android:layout_width="15dp"
                                        android:layout_height="15dp"
                                        android:src="@drawable/ic_fire"
                                        android:layout_marginEnd="5dp"
                                        app:tint="#FFA07A"
                                        android:contentDescription="Streak"/>

                                    <TextView
                                        android:id="@+id/tvStreak"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 Days"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#FFFFFF"
                                        android:fontFamily="@font/visby_bold"/>
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Row 2: Badges pill -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/bg_semi_white_pill"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="7dp"
                                android:paddingBottom="7dp"
                                android:layout_marginTop="8dp">

                                <ImageView
                                    android:layout_width="15dp"
                                    android:layout_height="15dp"
                                    android:src="@drawable/ic_badge"
                                    android:layout_marginEnd="5dp"
                                    app:tint="#93C5FD"
                                    android:contentDescription="Badges"/>

                                <TextView
                                    android:id="@+id/tvBadges"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 Badges"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/visby_bold"/>
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Leo mascot (right side of header) -->
                        <ImageView
                            android:id="@+id/ivLeoMascot"
                            android:layout_width="90dp"
                            android:layout_height="100dp"
                            android:src="@drawable/leo_placement_test"
                            android:scaleType="fitEnd"
                            android:contentDescription="Leo Mascot"/>
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- ═══════════════════════════════════════════════════════════
                 WHITE CONTENT SECTION — rounded top, overlaps header 24dp
                 ═══════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_top_rounded"
                android:layout_marginTop="-24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="20dp">

                <!-- ═══════════════════════════════════════════════════════════
                     CERTIFICATE BANNER — shown only after post-assessment
                     ═══════════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/cardCertificateBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_gradient_purple"
                    android:padding="16dp"
                    android:layout_marginBottom="18dp"
                    android:visibility="gone">

                    <!-- Emoji / icon column -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎓"
                        android:textSize="36sp"
                        android:layout_marginEnd="14dp"/>

                    <!-- Text column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Certificate Earned!"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/visby_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="You completed the English Reading Program"
                            android:textColor="#DDDDFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/visby_regular"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Action button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRePrintCertificate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View &amp; Share"
                        android:textSize="12sp"
                        android:textColor="@color/purple_700"
                        app:backgroundTint="#FFFFFF"
                        app:cornerRadius="20dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <!-- SECTION HEADER: "Your Learning Path" + sparkle Lottie -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Learning Path"
                            android:textSize="19sp"
                            android:textStyle="bold"
                            android:textColor="#2D3436"
                            android:fontFamily="@font/visby_bold"/>

                        <TextView
                            android:id="@+id/tvModuleSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Modules prioritized by your needs"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:fontFamily="@font/visby_regular"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Sparkle Lottie on the section header -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieStatsSparkle"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:lottie_rawRes="@raw/lottie_sparkle_stars"
                        app:lottie_loop="true"
                        app:lottie_autoPlay="true"
                        android:alpha="0.8"/>
                </LinearLayout>

                <!-- Modules RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvModules"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginTop="8dp"/>

                <!-- Bottom spacing for floating nav -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Bottom Navigation -->
    <include
        android:id="@+id/customBottomNav"
        layout="@layout/custom_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tutorial Overlay -->
    <include layout="@layout/tutorial_dashboard_overlay"/>

</androidx.constraintlayout.widget.ConstraintLayout>
