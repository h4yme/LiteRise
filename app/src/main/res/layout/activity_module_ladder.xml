<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1D2E">

    <!-- Top Bar — purple gradient matching dashboard -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_purple"
        android:elevation="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <!-- Back + Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/moduleTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Phonics and Word Study"
                android:fontFamily="@font/visby_bold"
                android:textSize="20sp"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Lottie sparkle decoration (top right) -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/sectionLottie"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:lottie_rawRes="@raw/lottie_sparkle_stars"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                android:alpha="0.85" />

        </LinearLayout>

        <!-- Progress row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress"
                android:fontFamily="@font/visby_regular"
                android:textSize="12sp"
                android:textColor="#E8DDFF"
                android:layout_marginEnd="10dp" />

            <ProgressBar
                android:id="@+id/moduleProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:layout_weight="1"
                android:progressDrawable="@drawable/progress_bar_drawable"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="0%"
                android:fontFamily="@font/visby_bold"
                android:textSize="13sp"
                android:textColor="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable path -->
    <ScrollView
        android:id="@+id/ladderScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:fillViewport="false">

        <com.example.literise.views.ModulePathView
            android:id="@+id/modulePathView"
            android:layout_width="match_parent"
            android:layout_height="2200dp" />

    </ScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1A1D2E"
        android:visibility="gone"
        android:clickable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#7C3AED" />

    </FrameLayout>

</RelativeLayout>
