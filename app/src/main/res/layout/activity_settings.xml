<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Purple Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_purple"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="44dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Back Button -->
                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_arrow_back"
                        android:background="@drawable/icon_circle_white"
                        android:padding="9dp"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="Back"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/visby_bold"/>

                </LinearLayout>

            </FrameLayout>

            <!-- White Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_top_rounded"
                android:layout_marginTop="-24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="40dp">

                <!-- Learning Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEARNING"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>

                <!-- Voice Speed Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_chip_purple"
                                android:layout_marginEnd="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_volume_up"
                                    app:tint="#7C3AED"
                                    android:contentDescription="Voice"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Voice Speed"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1F2937"
                                android:fontFamily="@font/visby_bold"/>
                        </LinearLayout>

                        <!-- Speed Selector -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_seg_control_track"
                            android:padding="4dp">

                            <TextView
                                android:id="@+id/btnVoiceNormal"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Normal"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/visby_bold"
                                android:gravity="center"
                                android:background="@drawable/bg_voice_speed_selected"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView
                                android:id="@+id/btnVoiceSlow"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Slow"
                                android:textSize="13sp"
                                android:textColor="#6B7280"
                                android:fontFamily="@font/visby_medium"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Audio Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AUDIO"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="4dp"/>

                <!-- Sounds Toggle Row -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_chip_purple"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_volume_up"
                                app:tint="#7C3AED"
                                android:contentDescription="Sounds"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sound Effects"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1F2937"
                                android:fontFamily="@font/visby_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Play sounds during lessons"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF"
                                android:fontFamily="@font/visby_regular"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchSounds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="#FFFFFF"
                            app:trackTint="@color/purple_500"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Offline Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFLINE"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="12dp"/>

                <!-- Download Lessons Row -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_chip_purple"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_book"
                                app:tint="#7C3AED"
                                android:contentDescription="Download"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Download Lessons"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1F2937"
                                android:fontFamily="@font/visby_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Access lessons without internet"
                                android:textSize="12sp"
                                android:textColor="#9CA3AF"
                                android:fontFamily="@font/visby_regular"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchDownload"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:thumbTint="#FFFFFF"
                            app:trackTint="@color/purple_500"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- About Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="12dp"/>

                <!-- About App Row -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAboutApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_chip_purple"
                            android:layout_marginEnd="14dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_info"
                                app:tint="#7C3AED"
                                android:contentDescription="About"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="About LiteRise"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1F2937"
                            android:fontFamily="@font/visby_bold"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="#9CA3AF"
                            android:contentDescription="Go"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
