<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.LoginActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_splash_login"
        android:scaleType="centerCrop"
        android:contentDescription="Placement Test Background" />

    <ImageView
        android:id="@+id/ivFloatingElements"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:alpha="0.6"
        android:contentDescription="Floating educational elements"
        android:scaleType="centerCrop"
        android:src="@drawable/login_floating2" />

    <!-- Content ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Top Spacer -->
            <View
                android:layout_width="1dp"
                android:layout_height="60dp" />

            <!-- Welcome Card -->
            <androidx.cardview.widget.CardView
                android:layout_marginTop="55dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Welcome Heading -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/visby_bold"
                        android:text="Welcome Learners!"
                        android:textColor="#2D3436"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <!-- Subtitle -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp"
                        android:fontFamily="@font/visby_regular"
                        android:text="Enter your LRN to start your reading adventure"
                        android:textColor="#636E72"
                        android:textSize="15sp" />

                    <!-- LRN Label -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/visby_medium"
                        android:text="Learner Reference Number (LRN)"
                        android:textColor="#2D3436"
                        android:textSize="14sp" />

                    <!-- LRN Input -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_input_modern">

                        <TextView
                            android:id="@+id/tvLrnIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:text="🪪"
                            android:textSize="20sp" />

                        <EditText
                            android:id="@+id/etLrn"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toEndOf="@id/tvLrnIcon"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/visby_regular"
                            android:hint="e.g. 123456789012"
                            android:inputType="number"
                            android:maxLength="12"
                            android:paddingStart="12dp"
                            android:paddingEnd="20dp"
                            android:textColor="#2D3436"
                            android:textColorHint="#B2BEC3"
                            android:textSize="15sp" />

                    </RelativeLayout>

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:elevation="0dp"
                        android:fontFamily="@font/visby_bold"
                        android:text="Let's Read! 📚"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:backgroundTint="#FFC126"
                        app:cornerRadius="16dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Bottom Spacer -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Leo Character - Floating on Top Right -->
    <ImageView
        android:id="@+id/ivLeoWaiting"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="19dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="Leo waiting"
        android:src="@drawable/leo_waiting"
        android:elevation="10dp" />

</FrameLayout>
