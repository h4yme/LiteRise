<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp">

    <!-- Badge Image with locked overlay -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="6dp">

        <!-- Badge PNG -->
        <ImageView
            android:id="@+id/ivBadgeIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="Badge"/>

        <!-- Locked Overlay -->
        <FrameLayout
            android:id="@+id/flLockedOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3F0EFFE"
            android:visibility="gone">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="#9CA3AF"
                android:contentDescription="Locked"/>
        </FrameLayout>

        <!-- Earned checkmark badge -->
        <ImageView
            android:id="@+id/ivEarnedCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_check_circle"
            app:tint="#10B981"
            android:background="@drawable/bg_avatar_circle"
            android:padding="2dp"
            android:visibility="gone"
            android:contentDescription="Earned"/>

    </FrameLayout>

    <!-- Badge Name -->
    <TextView
        android:id="@+id/tvBadgeName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="2"
        android:textSize="10sp"
        android:textColor="#374151"
        android:fontFamily="@font/visby_bold"
        android:lineSpacingMultiplier="1.1"/>

</LinearLayout>
