<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/bg_dialog_rounded">

    <!-- Lottie Sparkle Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieTransition"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="4dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/lottie_sparkle_stars"
        app:lottie_speed="1.2" />

    <!-- Category Icon -->
    <TextView
        android:id="@+id/tvCategoryIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="📚"
        android:textSize="52sp" />

    <!-- Category Title -->
    <TextView
        android:id="@+id/tvCategoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/visby_bold"
        android:text="Great Job!"
        android:textColor="#2C3E50"
        android:textSize="26sp" />

    <!-- Category Name (pill chip) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#EDE9FF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/visby_bold"
            android:paddingBottom="8dp"
            android:paddingEnd="16dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:text="Category 2: Word Knowledge"
            android:textAlignment="center"
            android:textColor="@color/purple_600"
            android:textSize="14sp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Leo Message Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#FFFBEC"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#FFE099"
        app:strokeWidth="1.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/leo_happy" />

            <TextView
                android:id="@+id/tvLeoMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/visby_medium"
                android:lineSpacingExtra="2dp"
                android:text="Now let's test your word knowledge! You're doing amazing! 🌟"
                android:textColor="#92640B"
                android:textSize="13sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:fontFamily="@font/visby_bold"
        android:text="Let's Go!"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:backgroundTint="@color/purple_600"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_arrow_right"
        app:iconGravity="end"
        app:iconTint="@color/white" />

</LinearLayout>