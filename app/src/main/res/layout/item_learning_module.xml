<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <!-- Gradient background set programmatically -->
    <FrameLayout
        android:id="@+id/gradientBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Decorative circle — large, right side -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="-40dp"
            android:background="@drawable/icon_circle_white"/>

        <!-- Decorative circle — small, top-right -->
        <View
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="28dp"
            android:layout_marginTop="-20dp"
            android:background="@drawable/icon_circle_white"/>

        <!-- Main card content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:minHeight="140dp">

            <!-- TOP ROW: domain badge + priority + status icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Domain icon pill -->
                <LinearLayout
                    android:id="@+id/domainBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_semi_white_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <ImageView
                        android:id="@+id/ivDomainIcon"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_book"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="Domain"/>

                    <TextView
                        android:id="@+id/tvDomain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phonics"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/visby_bold"/>
                </LinearLayout>

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- Priority badge — circular -->
                <TextView
                    android:id="@+id/tvPriority"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="#1"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="@font/visby_bold"
                    android:gravity="center"
                    android:background="@drawable/icon_circle_white"/>

                <!-- Play / Lock icon -->
                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_play"
                    app:tint="#FFFFFF"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Status Icon"/>
            </LinearLayout>

            <!-- Module title -->
            <TextView
                android:id="@+id/tvModuleTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Module Title"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:fontFamily="@font/visby_bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="12dp"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Letter sounds and word patterns"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/visby_regular"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="3dp"/>

            <!-- Flexible spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- BOTTOM ROW: progress bar + stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="5dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="20"
                    android:progressBackgroundTint="#40FFFFFF"
                    android:progressTint="#FFFFFF"
                    android:secondaryProgressTint="#00000000"/>

                <!-- Score % -->
                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20%"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/visby_bold"
                    android:layout_marginStart="8dp"/>

                <!-- Separator dot -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"/>

                <!-- Lesson count -->
                <TextView
                    android:id="@+id/tvLessonCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 Lessons"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/visby_regular"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Locked overlay (shown only when module is locked) -->
        <LinearLayout
            android:id="@+id/lockOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#66000000"
            android:visibility="gone">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_lock"
                app:tint="#FFFFFF"
                android:contentDescription="Locked"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete previous to unlock"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:fontFamily="@font/visby_medium"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
