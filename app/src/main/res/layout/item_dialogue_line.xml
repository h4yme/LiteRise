<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDialogue"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: Avatar + Speaker + Text + Accuracy badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar emoji -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="👧"
                android:textSize="30sp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginEnd="12dp" />

            <!-- Speaker name + dialogue text -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSpeaker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speaker"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="3dp" />

                <TextView
                    android:id="@+id/tvDialogueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dialogue line text"
                    android:textSize="15sp"
                    android:textColor="#2D3748"
                    android:fontFamily="@font/poppins"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- Accuracy badge (shown after recording) -->
            <TextView
                android:id="@+id/tvAccuracyBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_chip_white"
                android:layout_marginStart="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Status text (Recording… / Checking pronunciation…) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recording…"
            android:textSize="12sp"
            android:textColor="#F59E0B"
            android:fontFamily="@font/poppins"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <!-- Record / Stop button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🎤 Record"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#7C3AED"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                app:cornerRadius="20dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#7C3AED"
                app:strokeWidth="2dp" />

            <!-- Play / Stop playback button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="▶ Play"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#2196F3"
                android:paddingHorizontal="16dp"
                android:visibility="gone"
                app:cornerRadius="20dp"
                app:backgroundTint="#FFFFFF"
                app:strokeColor="#2196F3"
                app:strokeWidth="2dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>