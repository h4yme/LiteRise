<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Purple Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_purple"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="48dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Badges"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/visby_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Collect them all!"
                                android:textSize="13sp"
                                android:textColor="#CCFFFFFF"
                                android:fontFamily="@font/visby_regular"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- Badge count pill -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_semi_white_pill"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_badge"
                                app:tint="#FFD700"
                                android:layout_marginEnd="6dp"
                                android:contentDescription="Badges"/>

                            <TextView
                                android:id="@+id/tvBadgeCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— / 15"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/visby_bold"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Progress bar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/progressBadges"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="10dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:progressBackgroundTint="#44FFFFFF"
                            android:progressTint="#FFD700"
                            android:max="15"
                            android:progress="0"/>

                        <TextView
                            android:id="@+id/tvBadgesEarned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/visby_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" / "
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF"
                            android:fontFamily="@font/visby_regular"/>

                        <TextView
                            android:id="@+id/tvBadgesTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15"
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF"
                            android:fontFamily="@font/visby_regular"/>

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>

            <!-- White Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_top_rounded"
                android:layout_marginTop="-24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <!-- Loading state -->
                <LinearLayout
                    android:id="@+id/layoutLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:indeterminateTint="#7C3AED"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading badges..."
                        android:textSize="13sp"
                        android:textColor="#9CA3AF"
                        android:fontFamily="@font/visby_regular"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/layoutEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_badge"
                        app:tint="#E5E7EB"
                        android:contentDescription="No badges"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No badges yet"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#9CA3AF"
                        android:fontFamily="@font/visby_bold"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete lessons to earn your first badge!"
                        android:textSize="13sp"
                        android:textColor="#9CA3AF"
                        android:fontFamily="@font/visby_regular"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <!-- Badge Grid (all 15 badges, earned + locked) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBadges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>

                <!-- Bottom spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Bottom Navigation -->
    <include
        android:id="@+id/customBottomNav"
        layout="@layout/custom_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
