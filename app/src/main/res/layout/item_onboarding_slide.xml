<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2D1B6B">

    <!-- Full-screen Lottie (elements float across whole canvas) -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_speed="1.0" />

    <!-- Gradient + text pinned to bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_slide_bottom"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/tvSlideTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/visby_bold"
            android:lineSpacingExtra="2dp"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSlideDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/visby_regular"
            android:lineSpacingExtra="4dp"
            android:textColor="#CCB8FF"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
