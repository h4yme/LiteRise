<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center"
            android:weightSum="5">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="30dp">

                    <View
                        android:id="@+id/indicatorHome"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_nav_pill_indicator"
                        android:visibility="visible"/>

                    <ImageView
                        android:id="@+id/iconHome"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_home_filled"
                        app:tint="#7C3AED"
                        android:contentDescription="Home"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/labelHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="10sp"
                    android:textColor="#7C3AED"
                    android:fontFamily="@font/visby_bold"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Modules -->
            <LinearLayout
                android:id="@+id/navModules"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="30dp">

                    <View
                        android:id="@+id/indicatorModules"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_nav_pill_indicator"
                        android:visibility="invisible"/>

                    <ImageView
                        android:id="@+id/iconModules"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_book"
                        app:tint="#9CA3AF"
                        android:contentDescription="Modules"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/labelModules"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modules"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_regular"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Progress -->
            <LinearLayout
                android:id="@+id/navProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="30dp">

                    <View
                        android:id="@+id/indicatorProgress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_nav_pill_indicator"
                        android:visibility="invisible"/>

                    <ImageView
                        android:id="@+id/iconProgress"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chart"
                        app:tint="#9CA3AF"
                        android:contentDescription="Progress"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/labelProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_regular"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Badges -->
            <LinearLayout
                android:id="@+id/navBadges"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="30dp">

                    <View
                        android:id="@+id/indicatorBadges"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_nav_pill_indicator"
                        android:visibility="invisible"/>

                    <ImageView
                        android:id="@+id/iconBadges"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_badge"
                        app:tint="#9CA3AF"
                        android:contentDescription="Badges"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/labelBadges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Badges"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_regular"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="30dp">

                    <View
                        android:id="@+id/indicatorProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_nav_pill_indicator"
                        android:visibility="invisible"/>

                    <ImageView
                        android:id="@+id/iconProfile"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        app:tint="#9CA3AF"
                        android:contentDescription="Profile"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/labelProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="@font/visby_regular"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
