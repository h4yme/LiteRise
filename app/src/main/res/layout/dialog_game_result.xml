<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="24dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_result_header">

            <!-- Trophy circle -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_circle_white_alpha">

                <ImageView
                    android:id="@+id/ivTrophy"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trophy"
                    app:tint="@color/color_sunglow"/>

            </FrameLayout>

        </LinearLayout>

        <!-- Body content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:id="@+id/tvResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Great Job!"
                android:textSize="26sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvResultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You did awesome!"
                android:textSize="13sp"
                android:fontFamily="@font/poppins"
                android:textColor="@color/gray_dark"
                android:layout_marginBottom="20dp"/>

            <!-- Stats Row 1: Score + Accuracy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_stat_card">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/color_sunglow"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResultScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvLabelScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Score"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/gray_dark"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_stat_card">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_success"
                        app:tint="@color/color_jade1"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResultAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvLabelAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accuracy"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/gray_dark"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Stats Row 2: Streak + Time/Extra -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_stat_card">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_fire"
                        app:tint="@color/combo_orange"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResultStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvLabelStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Best Streak"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/gray_dark"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_stat_card">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_timer"
                        app:tint="@color/color_info_bg"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResultTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvLabelTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/gray_dark"/>

                </LinearLayout>

            </LinearLayout>

            <!-- XP Badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/color_sunglow">

                <TextView
                    android:id="@+id/tvResultXP"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="10dp"
                    android:text="+500 XP"
                    android:textSize="17sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/white"/>

            </androidx.cardview.widget.CardView>

            <!-- Continue Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinish"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Continue"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                app:backgroundTint="@color/color_jade1"
                app:cornerRadius="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <!-- Play Again Button (hidden by default) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Play Again"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/purple_600"
                app:backgroundTint="@color/gray_light"
                app:cornerRadius="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
