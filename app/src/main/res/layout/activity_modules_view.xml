<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EFFE">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Purple Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_purple"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="44dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Modules"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/visby_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your personalized English learning path"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:fontFamily="@font/visby_regular"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- White Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_top_rounded"
                android:layout_marginTop="-24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <!-- Overall Progress Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#7C3AED"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overall Progress"
                            android:textSize="13sp"
                            android:textColor="#CCFFFFFF"
                            android:fontFamily="@font/visby_regular"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvOverallPercent"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="0%"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/visby_bold"/>

                            <TextView
                                android:id="@+id/tvOverallLessons"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 / 0 lessons"
                                android:textSize="13sp"
                                android:textColor="#CCFFFFFF"
                                android:fontFamily="@font/visby_regular"/>
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressOverall"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="10dp"
                            android:progressBackgroundTint="#55FFFFFF"
                            android:progressTint="#FFFFFF"
                            android:max="100"
                            android:progress="0"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Section Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Modules"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2D3436"
                    android:fontFamily="@font/visby_bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Modules List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvModulesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>

                <!-- Bottom spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Bottom Navigation -->
    <include
        android:id="@+id/customBottomNav"
        layout="@layout/custom_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
