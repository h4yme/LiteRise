<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game">

    <!-- ── HEADER (module gradient applied in code) ── -->
    <LinearLayout
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#7C3AED"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Row 1: back + title + score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvModuleLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Module"
                    android:textSize="10sp"
                    android:textColor="#FFFFFFCC"
                    android:fontFamily="@font/poppins"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fill in the Blanks"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/white" />

            </LinearLayout>

            <!-- Score badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/rounded_bg_accent"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_star"
                    app:tint="#FFD700" />

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#FFD700"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Row 2: timer + progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_timer"
                app:tint="#FFFFFF99" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:00"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="10dp" />

            <ProgressBar
                android:id="@+id/timerProgress"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_weight="1"
                android:max="180"
                android:progress="180"
                android:progressTint="#FFFFFF"
                android:progressBackgroundTint="#FFFFFF44" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/10"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- Progress bar (questions) -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:max="10"
            android:progress="1"
            android:progressTint="#FFD700"
            android:progressBackgroundTint="#FFFFFF44" />

    </LinearLayout>

    <!-- ── HOW TO PLAY CARD ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/howToPlayCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#EEF2FF"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💡 Tap a word from the bank to fill the blank, then tap Check!"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textColor="#4338CA" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── QUESTION CARD ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/questionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/howToPlayCard"
        app:layout_constraintBottom_toTopOf="@id/wordBankCard"
        app:layout_constraintVertical_bias="0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 Complete the Sentence"
                android:textSize="13sp"
                android:textColor="#7C3AED"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginBottom="12dp" />

            <!-- Sentence with blank in the middle -->
            <!-- AFTER (fixed) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvQuestionBefore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The cat"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#1F2937"
                    android:lineSpacingExtra="4dp" />

                <!-- Blank space -->
                <TextView
                    android:id="@+id/tvBlank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="______"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#7C3AED"
                    android:layout_marginHorizontal="6dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_blank_space" />

                <TextView
                    android:id="@+id/tvQuestionAfter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="on the mat."
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="#1F2937"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── WORD BANK CARD (gradient applied in code) ── -->
    <LinearLayout
        android:id="@+id/wordBankCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="#7C3AED"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/questionCard"
        app:layout_constraintBottom_toTopOf="@id/btnCheckAnswer"
        app:layout_constraintHeight_min="120dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬 Word Bank"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerWordOptions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:scrollbars="none" />

    </LinearLayout>

    <!-- ── CHECK ANSWER BUTTON ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckAnswer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="Check Answer"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_bold"
        app:cornerRadius="18dp"
        app:backgroundTint="#10B981"
        android:textColor="#FFFFFF"
        app:icon="@drawable/ic_check"
        app:iconGravity="textStart"
        app:iconTint="#FFFFFF"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>