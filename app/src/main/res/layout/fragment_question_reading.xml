<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Reading Passage Card (gradient purple) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/readingPassageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_purple"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- "Read this passage" label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:text="📖"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/visby_bold"
                        android:text="Read this passage"
                        android:textColor="#D8CAFF"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Reading Text -->
                <TextView
                    android:id="@+id/tvReadingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/visby_medium"
                    android:lineSpacingExtra="7dp"
                    android:text="The cat sat on the mat. It was a sunny day."
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <!-- Done Reading Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoneReading"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/visby_bold"
                    android:text="Done Reading →"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:cornerRadius="20dp"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="1.5dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Comprehension Question Card (shown after Done Reading) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/comprehensionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:strokeColor="#EDE9FF"
            app:strokeWidth="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Comprehension Question -->
                <TextView
                    android:id="@+id/tvComprehensionQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/visby_bold"
                    android:layout_marginBottom="14dp"
                    android:lineSpacingExtra="3dp"
                    android:text="What did the cat sit on?"
                    android:textColor="#2C3E50"
                    android:textSize="15sp" />

                <!-- Answer Options -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnswer1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/visby_bold"
                    android:text="A mat"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_600"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_600"
                    app:strokeWidth="1.5dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnswer2"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/visby_bold"
                    android:text="A chair"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_600"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_600"
                    app:strokeWidth="1.5dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnswer3"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/visby_bold"
                    android:text="A table"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_600"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_600"
                    app:strokeWidth="1.5dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnswer4"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/visby_bold"
                    android:text="A box"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_600"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/purple_600"
                    app:strokeWidth="1.5dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
