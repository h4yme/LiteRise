<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:padding="8dp"
            app:tint="@color/white"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pronunciation Practice"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="@font/visby_bold"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 8"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/bg_chip_white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </LinearLayout>

    <!-- ── Stats row ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tv_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ 0"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_semibold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF">
            <TextView
                android:id="@+id/tv_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 0"
                android:textSize="15sp"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_semibold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ── Instruction ────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Listen, then Speak the word"
        android:textSize="14sp"
        android:textColor="#CCFFFFFF"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/statsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Word card ──────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_word"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_instruction"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tv_target_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHIP"
                android:textSize="56sp"
                android:textColor="@color/purple_600"
                android:fontFamily="@font/visby_bold"
                android:letterSpacing="0.05"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_contrast_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not: sheep"
                android:textSize="13sp"
                android:textColor="@color/gray_medium"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="6dp" />

            <!-- Recording progress bar -->
            <ProgressBar
                android:id="@+id/pb_recording"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="20dp"
                android:progressTint="@color/color_error"
                android:progressBackgroundTint="#1AEF4444"
                android:visibility="gone" />

            <!-- Waveform indicator (animated bar) -->
            <View
                android:id="@+id/waveform_view"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:background="#FFEF4444"
                android:visibility="gone" />

            <!-- Accuracy bar -->
            <ProgressBar
                android:id="@+id/pb_accuracy"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="20dp"
                android:progressTint="@color/jade1"
                android:progressBackgroundTint="#1A11B067"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_accuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:fontFamily="@font/visby_bold"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_recognized"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/gray_medium"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Feedback chip ──────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_feedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_feedback_chip"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/card_word"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Action buttons ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_feedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_listen"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Listen"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_semibold"
            app:icon="@drawable/ic_volume_up"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            app:cornerRadius="16dp"
            android:backgroundTint="#26FFFFFF"
            android:textColor="@color/white"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_speak"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="🎤  Speak"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_semibold"
            app:cornerRadius="16dp"
            android:backgroundTint="@color/jade1"
            android:textColor="@color/white"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- ── Help + Next ────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/actionButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_show_help"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Help"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            app:icon="@drawable/ic_help"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:cornerRadius="14dp"
            android:backgroundTint="#33FFFFFF"
            android:textColor="@color/white"
            android:layout_marginEnd="12dp"
            style="@style/Widget.MaterialComponents.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Next Word"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_semibold"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="end"
            app:iconSize="18dp"
            app:cornerRadius="14dp"
            android:backgroundTint="@color/purple_600"
            android:textColor="@color/white"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>