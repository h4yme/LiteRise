{
  "info": {
    "name": "LiteRise - Evaluate Pronunciation API",
    "description": "Tests for evaluate_pronunciation.php — covers auth, validation, item lookup, and the happy path.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://literiseapi-bgfcfgdydvc6djhk.southeastasia-01.azurewebsites.net",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PASTE_YOUR_JWT_TOKEN_HERE",
      "type": "string",
      "description": "Bearer token from login response. Grab it from SessionManager / logcat."
    },
    {
      "key": "student_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "item_id",
      "value": "221",
      "type": "string",
      "description": "The ItemID sent by the app (change to match your test session)"
    },
    {
      "key": "target_word",
      "value": "spring",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. No Token (expect 401)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "{{student_id}}", "type": "text" },
            { "key": "item_id",     "value": "{{item_id}}",    "type": "text" },
            { "key": "session_id",  "value": "12345",          "type": "text" },
            { "key": "response_id", "value": "99999",          "type": "text" },
            { "key": "target_word", "value": "{{target_word}}","type": "text" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "Omit Authorization header — server must return 401 Authentication required."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401', () => pm.response.to.have.status(401));",
              "const json = pm.response.json();",
              "pm.test('success=false', () => pm.expect(json.success).to.be.false);",
              "pm.test('error contains auth', () => pm.expect(json.error.toLowerCase()).to.include('auth'));"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Missing required fields (expect 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id", "value": "{{student_id}}", "type": "text" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "Send only student_id — item_id and target_word are missing."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('success=false', () => pm.expect(json.success).to.be.false);"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Missing audio file (expect 400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "{{student_id}}", "type": "text" },
            { "key": "item_id",     "value": "{{item_id}}",    "type": "text" },
            { "key": "session_id",  "value": "12345",          "type": "text" },
            { "key": "response_id", "value": "99999",          "type": "text" },
            { "key": "target_word", "value": "{{target_word}}","type": "text" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "All fields present but no audio_file — server must return 400."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('success=false', () => pm.expect(json.success).to.be.false);",
              "pm.test('error mentions audio', () => pm.expect(json.error.toLowerCase()).to.include('audio'));"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Wrong student_id (expect 403)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "9999",           "type": "text",
              "description": "ID that doesn't match the token" },
            { "key": "item_id",     "value": "{{item_id}}",    "type": "text" },
            { "key": "session_id",  "value": "12345",          "type": "text" },
            { "key": "response_id", "value": "99999",          "type": "text" },
            { "key": "target_word", "value": "{{target_word}}","type": "text" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "Token belongs to student 1 but student_id=9999 — should be 403."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 403', () => pm.response.to.have.status(403));",
              "const json = pm.response.json();",
              "pm.test('success=false', () => pm.expect(json.success).to.be.false);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Non-existent item_id — soft lookup (expect NOT 404)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "{{student_id}}", "type": "text" },
            { "key": "item_id",     "value": "999999",         "type": "text",
              "description": "An item that almost certainly doesn't exist" },
            { "key": "session_id",  "value": "12345",          "type": "text" },
            { "key": "response_id", "value": "99999",          "type": "text" },
            { "key": "target_word", "value": "{{target_word}}","type": "text" },
            { "key": "audio_file",  "value": "",               "type": "file",
              "src": "ATTACH_ANY_SMALL_AUDIO_FILE",
              "description": "Attach a real .3gp or .wav file" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "KEY TEST: after the soft-lookup fix, this must NOT return 404. It should proceed with target_word fallback and return 200 or 500 (Google Cloud issue), never 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is NOT 404 (soft lookup working)', () => pm.response.to.not.have.status(404));",
              "pm.test('Response is JSON (not nginx HTML)', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('json');",
              "});",
              "const json = pm.response.json();",
              "pm.test('Has success field', () => pm.expect(json).to.have.property('success'));"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Happy path — real audio (expect 200)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "{{student_id}}", "type": "text" },
            { "key": "item_id",     "value": "{{item_id}}",    "type": "text" },
            { "key": "session_id",  "value": "1772598177",     "type": "text" },
            { "key": "response_id", "value": "1772598188",     "type": "text" },
            { "key": "target_word", "value": "{{target_word}}","type": "text" },
            { "key": "audio_file",  "value": "",               "type": "file",
              "src": "ATTACH_YOUR_RECORDING_3GP",
              "description": "Pull the .3gp from device: adb pull /data/user/0/com.example.literise/cache/pronunciation/<filename>.3gp" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "Full happy-path test. Attach a real recording pulled from the device via adb."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is JSON', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('json');",
              "});",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.be.true);",
              "pm.test('Has pronunciation_result', () => pm.expect(json).to.have.property('pronunciation_result'));",
              "const r = json.pronunciation_result;",
              "pm.test('overall_accuracy is a number', () => pm.expect(r.overall_accuracy).to.be.a('number'));",
              "pm.test('passed is boolean', () => pm.expect(r.passed).to.be.a('boolean'));",
              "pm.test('feedback is a string', () => pm.expect(r.feedback).to.be.a('string'));"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Check DB — does item 221 exist?",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "student_id",  "value": "{{student_id}}", "type": "text" },
            { "key": "item_id",     "value": "221",            "type": "text" },
            { "key": "session_id",  "value": "1772598177",     "type": "text" },
            { "key": "response_id", "value": "1772598188",     "type": "text" },
            { "key": "target_word", "value": "spring",         "type": "text" },
            { "key": "audio_file",  "value": "",               "type": "file",
              "src": "ATTACH_YOUR_RECORDING_3GP" }
          ]
        },
        "url": "{{base_url}}/evaluate_pronunciation.php",
        "description": "Same params the app sends. If it STILL returns 404 after the fix, the issue is deeper (Google Cloud vendor libs missing = fatal PHP error, nginx shows 404). If it returns 500, check Azure error logs for the exact PHP error."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const status = pm.response.code;",
              "pm.test('Not nginx 404 anymore', () => {",
              "    if (status === 404) {",
              "        pm.expect.fail('Still getting nginx 404 — fix not deployed yet OR vendor/autoload.php is missing on server');",
              "    }",
              "});",
              "pm.test('Response is JSON (not nginx HTML)', () => {",
              "    const ct = pm.response.headers.get('Content-Type') || '';",
              "    pm.expect(ct).to.include('json');",
              "});",
              "",
              "if (status === 200) {",
              "    const json = pm.response.json();",
              "    pm.test('[200] success=true', () => pm.expect(json.success).to.be.true);",
              "} else if (status === 500) {",
              "    const json = pm.response.json();",
              "    pm.test('[500] success=false — check Azure logs for PHP error', () => pm.expect(json.success).to.be.false);",
              "    console.log('Server error:', json.error);",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
