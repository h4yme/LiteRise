{
  "info": {
    "name": "LiteRise API",
    "description": "Full API test collection for LiteRise. Base URL: http://192.168.1.13/api\n\nHow to use:\n1. Import this file into Postman\n2. Set the 'base_url' collection variable if your IP changes\n3. Run '01 Auth > Register' then '01 Auth > Login' first — the login request auto-saves {{token}} and {{student_id}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://192.168.1.13/api" },
    { "key": "token",      "value": "" },
    { "key": "student_id", "value": "1" },
    { "key": "node_id",    "value": "1" },
    { "key": "module_id",  "value": "1" }
  ],
  "item": [

    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/register.php",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Maria\",\n  \"last_name\": \"Santos\",\n  \"email\": \"maria.santos@test.com\",\n  \"password\": \"Test1234!\",\n  \"grade_level\": 3\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.collectionVariables.set('student_id', res.student?.student_id ?? res.student_id ?? '');",
                  "  console.log('Token saved:', res.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/login.php",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria.santos@test.com\",\n  \"password\": \"Test1234!\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/forgot_password.php",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"maria.santos@test.com\"\n}"
            }
          }
        }
      ]
    },

