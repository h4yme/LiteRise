@{
    ViewBag.Title = "Progress Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles { <link rel="stylesheet" href="/Content/TeacherReportsStyles.css" /> }

<div class="reports-page">

    <!-- ══════════════════════════════════════════════════════════════════
         PAGE HEADER
    ══════════════════════════════════════════════════════════════════ -->
    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title">Progress Reports</h1>
            <p class="page-subtitle">
                Generate and export reports for
                <strong>@ViewBag.SchoolName</strong>
            </p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning alert-dismissible" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Warning:</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- ══════════════════════════════════════════════════════════════════
         REPORT CARDS ROW
    ══════════════════════════════════════════════════════════════════ -->
    <div class="report-cards-row">

        <!-- ── Card 1: Individual Student Report ─────────────────────── -->
        <div class="report-card">
            <div class="report-card-icon">
                <i class="fas fa-user-graduate"></i>
            </div>
            <h3>Individual Student Report</h3>
            <p class="desc">
                Generate a detailed progress report for a single student, including
                assessment scores, lesson completion, and module progress.
            </p>

            <div class="form-group mb-3">
                <label for="studentSelect" class="form-label">Select Student</label>
                <select id="studentSelect" class="form-select">
                    <option value="">— Choose a student —</option>
                </select>
            </div>

            <div class="btn-group-stack">
                <button id="generateStudentBtn" class="btn btn-primary" onclick="generateStudentReport()">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </button>
            </div>
        </div>

        <!-- ── Card 2: Class Summary Report ──────────────────────────── -->
        <div class="report-card">
            <div class="report-card-icon report-card-icon--class">
                <i class="fas fa-users"></i>
            </div>
            <h3>Class Summary Report</h3>
            <p class="desc">
                Export a full summary of all
                <strong>@(ViewBag.TotalStudents)</strong> students, including level
                distribution, average assessment scores, and lesson progress.
            </p>

            <div class="btn-group-stack">
                <button id="generateClassBtn" class="btn btn-primary" onclick="generateClassReport()">
                    <i class="fas fa-print me-2"></i>Generate Class Report
                </button>
                <button id="exportCsvBtn" class="btn btn-outline-secondary" onclick="exportCsv()">
                    <i class="fas fa-file-csv me-2"></i>Export CSV
                </button>
            </div>
        </div>

    </div><!-- /.report-cards-row -->

    <!-- ══════════════════════════════════════════════════════════════════
         REPORT PREVIEW AREA
    ══════════════════════════════════════════════════════════════════ -->
    <div class="report-section">
        <div class="report-section-header">
            <h3><i class="fas fa-eye me-2 text-secondary"></i>Report Preview</h3>
            <div id="trPreviewActions" style="display:none;">
                <button class="btn btn-outline-secondary btn-sm" onclick="printReport()">
                    <i class="fas fa-print me-1"></i>Print / Save PDF
                </button>
            </div>
        </div>

        <div id="reportPreview" class="report-preview-area">
            <div class="text-center py-5" style="color:#9ca3af;" id="trPreviewPlaceholder">
                <i class="fas fa-file-alt" style="font-size:3rem;margin-bottom:16px;display:block;opacity:0.4;"></i>
                <p class="mb-0" style="font-size:15px;">Select a student and click <strong>Generate Report</strong> to preview.</p>
                <p class="mt-2" style="font-size:13px;">The report will appear here before printing or saving.</p>
            </div>
        </div>
    </div>

</div><!-- /.reports-page -->

<!-- ── Toast notification container ──────────────────────────────────── -->
<div id="trToastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
</div>

<!-- ── Loading overlay ────────────────────────────────────────────────── -->
<div class="loading-overlay" id="trLoadingOverlay">
    <div class="loading-box">
        <div class="spinner"></div>
        <p id="trLoadingMessage">Generating report…</p>
    </div>
</div>

<!-- ── Inject student data for JS ─────────────────────────────────────── -->
<script>
    window.studentsData = @Html.Raw(ViewBag.StudentsJson ?? "[]");
</script>

@section scripts { <script src="/Scripts/TeacherReportsScript.js?v=3"></script> }
