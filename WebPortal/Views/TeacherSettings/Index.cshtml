@{
    ViewBag.Title = "Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles { <link rel="stylesheet" href="/Content/TeacherSettingsStyles.css" /> }

<div class="settings-wrapper">

    <!-- ══════════════════════════════════════════════════════════════════
         PAGE HEADER
    ══════════════════════════════════════════════════════════════════ -->
    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title">Settings</h1>
            <p class="page-subtitle">Manage your profile, password, and assigned students</p>
        </div>
        <div class="page-header-right">
            <span class="user-badge">
                <i class="fas fa-chalkboard-teacher"></i>
                <span id="headerUserName">@ViewBag.UserName</span>
            </span>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TWO-COLUMN LAYOUT
    ══════════════════════════════════════════════════════════════════ -->
    <div class="settings-layout">

        <!-- ── LEFT SIDEBAR ───────────────────────────────────────────── -->
        <aside class="settings-sidebar">
            <div class="sidebar-header">
                <div class="avatar-circle" id="sidebarAvatar">T</div>
                <div class="sidebar-user-info">
                    <span class="sidebar-name" id="sidebarName">@ViewBag.UserName</span>
                    <span class="sidebar-role">Teacher</span>
                </div>
            </div>
            <ul class="sidebar-nav">
                <li>
                    <a href="#" class="nav-link active" data-section="profile">
                        <i class="fas fa-user"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link" data-section="security">
                        <i class="fas fa-shield-alt"></i>
                        <span>Security</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link" data-section="students">
                        <i class="fas fa-user-graduate"></i>
                        <span>My Students</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- ── RIGHT CONTENT ──────────────────────────────────────────── -->
        <main class="settings-content">

            <!-- ── PROFILE SECTION ──────────────────────────────────── -->
            <section class="settings-section active" id="section-profile">
                <div class="section-header">
                    <h3><i class="fas fa-user me-2"></i>Profile</h3>
                    <p>Update your display name and email address.</p>
                </div>

                <div class="avatar-section">
                    <div class="avatar-circle large" id="profileAvatar">T</div>
                    <div class="avatar-info">
                        <h4 id="profileDisplayName">Loading...</h4>
                        <p id="profileSchool" class="text-muted" style="font-size:13px;">—</p>
                        <p class="text-muted" style="font-size:12px;">
                            Last login: <span id="profileLastLogin">—</span>
                        </p>
                    </div>
                </div>

                <form id="profileForm" onsubmit="return false;">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="profileName">Full Name</label>
                            <input type="text" id="profileName" class="input-field"
                                   placeholder="Enter your full name" autocomplete="name" />
                        </div>
                        <div class="form-group">
                            <label for="profileEmail">Email Address</label>
                            <input type="email" id="profileEmail" class="input-field"
                                   placeholder="Enter your email" autocomplete="email" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="profileSchoolField">School</label>
                            <input type="text" id="profileSchoolField" class="input-field" readonly />
                            <span class="hint">School assignment is managed by your administrator.</span>
                        </div>
                        <div class="form-group">
                            <label for="profileGrade">Assigned Grade</label>
                            <input type="text" id="profileGrade" class="input-field" readonly />
                            <span class="hint">Grade assignment is managed by your administrator.</span>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary-custom" onclick="saveProfile()">
                            <i class="fas fa-save me-1"></i> Save Profile
                        </button>
                    </div>
                </form>
            </section>

            <!-- ── SECURITY SECTION ─────────────────────────────────── -->
            <section class="settings-section" id="section-security">
                <div class="section-header">
                    <h3><i class="fas fa-shield-alt me-2"></i>Security</h3>
                    <p>Change your account password. Choose a strong password of at least 8 characters.</p>
                </div>

                <form id="passwordForm" onsubmit="return false;">
                    <div class="form-group">
                        <label for="currentPassword">Current Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="currentPassword" class="input-field"
                                   placeholder="Enter current password" autocomplete="current-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('currentPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="newPassword">New Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="newPassword" class="input-field"
                                   placeholder="Enter new password (min. 8 characters)"
                                   oninput="checkPasswordStrength(this.value)"
                                   autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('newPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <div class="password-strength">
                            <div class="strength-bar" id="strengthBar"></div>
                        </div>
                        <span class="strength-label" id="strengthLabel"></span>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm New Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="confirmPassword" class="input-field"
                                   placeholder="Re-enter new password" autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('confirmPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary-custom" onclick="changePassword()">
                            <i class="fas fa-lock me-1"></i> Change Password
                        </button>
                    </div>
                </form>
            </section>

            <!-- ── MY STUDENTS SECTION ──────────────────────────────── -->
            <section class="settings-section" id="section-students">
                <div class="section-header">
                    <h3><i class="fas fa-user-graduate me-2"></i>My Students</h3>
                    <p>View your assigned students. To add or remove a student, submit a request to your administrator.</p>
                </div>

                <div class="students-toolbar">
                    <input type="text" id="studentSearch" class="form-control form-control-sm"
                           placeholder="Search students..." oninput="filterStudents()" style="max-width:240px;" />
                    <button class="btn-primary-custom btn-sm-custom ms-auto" data-bs-toggle="modal" data-bs-target="#studentRequestModal">
                        <i class="fas fa-paper-plane me-1"></i> Request Student Change
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover student-table" id="studentsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Grade</th>
                                <th>Level</th>
                                <th>Last Active</th>
                            </tr>
                        </thead>
                        <tbody id="studentsTableBody">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin me-2"></i> Loading students...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="studentsEmpty" class="empty-state" style="display:none;">
                    <i class="fas fa-users-slash"></i>
                    <p>No students found matching your search.</p>
                </div>
            </section>

        </main>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     STUDENT CHANGE REQUEST MODAL
══════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="studentRequestModal" tabindex="-1"
     aria-labelledby="studentRequestModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="studentRequestModalLabel">
                    <i class="fas fa-paper-plane me-2"></i>Request Student Change
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="studentRequestForm" onsubmit="submitStudentRequest(event)">
                    <div class="form-group mb-3">
                        <label for="reqStudentName" class="form-label fw-semibold">Student Name</label>
                        <input type="text" id="reqStudentName" class="form-control"
                               placeholder="Enter the student's full name" required />
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">Action</label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reqAction"
                                       id="reqActionAdd" value="Add" checked />
                                <label class="form-check-label" for="reqActionAdd">
                                    <i class="fas fa-user-plus text-success me-1"></i> Add Student
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="reqAction"
                                       id="reqActionRemove" value="Remove" />
                                <label class="form-check-label" for="reqActionRemove">
                                    <i class="fas fa-user-minus text-danger me-1"></i> Remove Student
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-3">
                        <label for="reqReason" class="form-label fw-semibold">Reason</label>
                        <textarea id="reqReason" class="form-control" rows="4"
                                  placeholder="Please provide a reason for this request (min. 10 characters)..."
                                  required minlength="10"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="studentRequestForm" class="btn-primary-custom">
                    <i class="fas fa-paper-plane me-1"></i> Submit Request
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     TOAST CONTAINER
══════════════════════════════════════════════════════════════════ -->
<div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

@section scripts { <script src="/Scripts/TeacherSettingsScript.js"></script> }
