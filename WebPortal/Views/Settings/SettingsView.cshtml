@{
    ViewBag.Title = "Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section styles { <link rel="stylesheet" href="/Content/SettingsStyles.css" /> }

<div class="settings-wrapper">

    <!-- ══════════════════════════════════════════════════════════════════
         PAGE HEADER
    ══════════════════════════════════════════════════════════════════ -->
    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title">Settings</h1>
            <p class="page-subtitle">Manage your profile, security, and system configuration</p>
        </div>
        <div class="page-header-right">
            <span class="user-badge">
                <i class="fas fa-user-shield"></i>
                <span id="headerUserName">@ViewBag.UserName</span>
            </span>
            <button class="btn btn-outline-secondary btn-sm ms-2" id="toggleDarkMode">
                <i class="fas fa-moon"></i> Dark Mode
            </button>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         TWO-COLUMN LAYOUT
    ══════════════════════════════════════════════════════════════════ -->
    <div class="settings-layout">

        <!-- ── LEFT SIDEBAR ───────────────────────────────────────────── -->
        <aside class="settings-sidebar">
            <div class="sidebar-header">
                <div class="avatar-circle" id="sidebarAvatar">A</div>
                <div class="sidebar-user-info">
                    <span class="sidebar-name" id="sidebarName">@ViewBag.UserName</span>
                    <span class="sidebar-role">Administrator</span>
                </div>
            </div>
            <ul class="sidebar-nav">
                <li>
                    <a href="#" class="nav-link active" data-section="profile">
                        <i class="fas fa-user"></i>
                        <span>Profile</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link" data-section="security">
                        <i class="fas fa-shield-alt"></i>
                        <span>Security</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-link" data-section="audit">
                        <i class="fas fa-history"></i>
                        <span>Audit Log</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- ── RIGHT CONTENT ──────────────────────────────────────────── -->
        <main class="settings-content">

            <!-- ── PROFILE SECTION ──────────────────────────────────── -->
            <section class="settings-section active" id="section-profile">
                <div class="section-header">
                    <h3><i class="fas fa-user me-2"></i>Profile</h3>
                    <p>Update your display name and email address.</p>
                </div>

                <div class="avatar-section">
                    <div class="avatar-circle large" id="profileAvatar">A</div>
                    <div class="avatar-info">
                        <h4 id="profileDisplayName">Loading...</h4>
                        <p id="profileRole">Administrator</p>
                        <p class="text-muted" style="font-size:12px;">
                            Last login: <span id="profileLastLogin">—</span>
                        </p>
                    </div>
                </div>

                <form id="profileForm" onsubmit="return false;">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="profileName">Full Name</label>
                            <input type="text" id="profileName" class="input-field"
                                   placeholder="Enter your full name" autocomplete="name" />
                        </div>
                        <div class="form-group">
                            <label for="profileEmail">Email Address</label>
                            <input type="email" id="profileEmail" class="input-field"
                                   placeholder="Enter your email" autocomplete="email" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="profileRoleDisplay">Role</label>
                        <input type="text" id="profileRoleDisplay" class="input-field" readonly />
                        <span class="hint">Role cannot be changed from this panel.</span>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary-custom" onclick="saveProfile()">
                            <i class="fas fa-save me-1"></i> Save Profile
                        </button>
                    </div>
                </form>
            </section>

            <!-- ── SECURITY SECTION ─────────────────────────────────── -->
            <section class="settings-section" id="section-security">
                <div class="section-header">
                    <h3><i class="fas fa-shield-alt me-2"></i>Security</h3>
                    <p>Change your account password. Choose a strong password of at least 8 characters.</p>
                </div>

                <form id="passwordForm" onsubmit="return false;">
                    <div class="form-group">
                        <label for="currentPassword">Current Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="currentPassword" class="input-field"
                                   placeholder="Enter current password" autocomplete="current-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('currentPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="newPassword">New Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="newPassword" class="input-field"
                                   placeholder="Enter new password (min. 8 characters)"
                                   oninput="checkPasswordStrength(this.value)"
                                   autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('newPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <div class="password-strength">
                            <div class="strength-bar" id="strengthBar"></div>
                        </div>
                        <span class="strength-label" id="strengthLabel"></span>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm New Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="confirmPassword" class="input-field"
                                   placeholder="Re-enter new password" autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="toggleVisibility('confirmPassword', this)" aria-label="Show/hide password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary-custom" onclick="changePassword()">
                            <i class="fas fa-lock me-1"></i> Change Password
                        </button>
                    </div>
                </form>
            </section>

            <!-- ── AUDIT LOG SECTION ─────────────────────────────────── -->
            <section class="settings-section" id="section-audit">
                <div class="section-header">
                    <h3><i class="fas fa-history me-2"></i>Audit Log</h3>
                    <p>Recent administrative activity across the system.</p>
                </div>

                <div class="audit-filters">
                    <input type="text" id="auditSearch" class="form-control form-control-sm"
                           placeholder="Search actions or targets..." oninput="filterAuditLog()" style="max-width:240px;" />
                    <select id="auditActionFilter" class="form-select form-select-sm" onchange="filterAuditLog()" style="max-width:160px;">
                        <option value="">All Actions</option>
                        <option value="login">Login</option>
                        <option value="create">Create</option>
                        <option value="edit">Edit</option>
                        <option value="delete">Delete</option>
                        <option value="export">Export</option>
                    </select>
                    <button class="btn btn-outline-secondary btn-sm" onclick="loadAuditLog()">
                        <i class="fas fa-sync-alt"></i> Refresh
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover audit-table" id="auditTable">
                        <thead class="table-light">
                            <tr>
                                <th>Action</th>
                                <th>Admin</th>
                                <th>Target</th>
                                <th>Timestamp</th>
                                <th>IP Address</th>
                            </tr>
                        </thead>
                        <tbody id="auditTableBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin me-2"></i> Loading audit log...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

        </main>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     TOAST CONTAINER
══════════════════════════════════════════════════════════════════ -->
<div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

@section scripts { <script src="/Scripts/SettingsScript.js"></script> }
