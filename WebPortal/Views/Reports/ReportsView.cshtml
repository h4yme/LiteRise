@inherits System.Web.Mvc.WebViewPage
@{
    ViewBag.Title = "Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Styles.Render("~/Content/ReportsStyles.css")

<div class="reports-page">

    <!-- ══════════════════════════════════════════════════════════════════
         PAGE HEADER
    ══════════════════════════════════════════════════════════════════ -->
    <div class="page-header d-flex align-items-start justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1"><i class="fas fa-file-alt me-2 text-success"></i>Reports</h2>
            <p class="subtitle mb-0">Generate and export reports for students and schools</p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning alert-dismissible" role="alert">
            <strong>Warning:</strong> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ══════════════════════════════════════════════════════════════════
         REPORT CARDS GRID — 3 columns desktop, 1 mobile
    ══════════════════════════════════════════════════════════════════ -->
    <div class="row g-4 mb-4">

        <!-- ── Card 1: Student Progress Report ───────────────────────── -->
        <div class="col-12 col-md-6 col-xl-4">
            <div class="report-card h-100 d-flex flex-column">
                <div class="report-card-icon">
                    <i class="fas fa-user-graduate" style="color:#11B067;"></i>
                </div>
                <h4>Student Progress Report</h4>
                <p>Detailed pre/post assessment comparison, category breakdown, and lesson progress for one student.</p>

                <div class="mb-3 mt-auto">
                    <label for="studentSelect" class="form-label" style="font-size:13px;font-weight:600;margin-bottom:5px;">
                        Select Student
                    </label>
                    <select id="studentSelect" class="form-select form-select-sm">
                        <option value="">— Choose a student —</option>
                    </select>
                </div>

                <div class="report-card-actions">
                    <button class="btn-report primary" onclick="generateStudentReport()" id="btnGenStudent">
                        <i class="fas fa-chart-line"></i> Generate Report
                    </button>
                    <button class="btn-report outline" id="btnPrintStudent" onclick="printReport()" style="display:none;">
                        <i class="fas fa-print"></i> Print / Save PDF
                    </button>
                </div>
            </div>
        </div>

        <!-- ── Card 2: School Summary Report ─────────────────────────── -->
        <div class="col-12 col-md-6 col-xl-4">
            <div class="report-card h-100 d-flex flex-column">
                <div class="report-card-icon">
                    <i class="fas fa-school" style="color:#0d6efd;"></i>
                </div>
                <h4>School Summary Report</h4>
                <p>Average theta, lesson completion, and top performers per school.</p>

                <div class="mb-3 mt-auto">
                    <label for="schoolSelect" class="form-label" style="font-size:13px;font-weight:600;margin-bottom:5px;">
                        Select School
                    </label>
                    <select id="schoolSelect" class="form-select form-select-sm">
                        <option value="">— Choose a school —</option>
                    </select>
                </div>

                <div class="report-card-actions">
                    <button class="btn-report secondary" onclick="generateSchoolReport()" id="btnGenSchool">
                        <i class="fas fa-chart-bar"></i> Generate Report
                    </button>
                    <a href="/Reports/ExportSchoolsSummaryCsv" class="btn-report outline" id="btnExportSchools">
                        <i class="fas fa-file-csv"></i> Export CSV
                    </a>
                </div>
            </div>
        </div>

        <!-- ── Card 3: System Usage Report ───────────────────────────── -->
        <div class="col-12 col-md-6 col-xl-4">
            <div class="report-card h-100 d-flex flex-column">
                <div class="report-card-icon">
                    <i class="fas fa-chart-bar" style="color:#7c3aed;"></i>
                </div>
                <h4>System Usage Report</h4>
                <p>Login frequency, session durations, and active user trends.</p>

                <div class="mb-3 mt-auto">
                    <div class="d-flex gap-2 flex-wrap">
                        <div class="flex-fill">
                            <label for="startDate" class="form-label" style="font-size:12px;font-weight:600;margin-bottom:4px;">
                                Start Date
                            </label>
                            <input type="date" id="startDate" class="form-control form-control-sm">
                        </div>
                        <div class="flex-fill">
                            <label for="endDate" class="form-label" style="font-size:12px;font-weight:600;margin-bottom:4px;">
                                End Date
                            </label>
                            <input type="date" id="endDate" class="form-control form-control-sm">
                        </div>
                    </div>
                </div>

                <div class="report-card-actions">
                    <button class="btn-report primary" onclick="generateSystemReport()" id="btnGenSystem"
                            style="background:#7c3aed;border-color:#7c3aed;">
                        <i class="fas fa-cog"></i> Generate Report
                    </button>
                    <a href="/Reports/ExportStudentsCsv" class="btn-report outline">
                        <i class="fas fa-file-csv"></i> Export Students CSV
                    </a>
                </div>
            </div>
        </div>

    </div><!-- /.row -->

    <!-- ══════════════════════════════════════════════════════════════════
         REPORT PREVIEW AREA
    ══════════════════════════════════════════════════════════════════ -->
    <div class="report-section">
        <div class="report-section-header">
            <h3><i class="fas fa-eye me-2 text-secondary"></i>Report Preview</h3>
            <div id="previewActions" style="display:none;">
                <button class="btn-report outline" onclick="printReport()" id="btnPrintPreview">
                    <i class="fas fa-print"></i> Print / Save PDF
                </button>
            </div>
        </div>

        <div id="reportPreview" class="report-preview-area">
            <div class="text-center py-5" style="color:#9ca3af;" id="previewPlaceholder">
                <i class="fas fa-file-alt" style="font-size:3rem;margin-bottom:16px;display:block;opacity:0.4;"></i>
                <p class="mb-0" style="font-size:15px;">Select a report type and click <strong>Generate</strong> to preview.</p>
                <p class="mt-2" style="font-size:13px;">The report will appear here before printing or saving.</p>
            </div>
        </div>
    </div>

</div><!-- /.reports-page -->

<!-- ══════════════════════════════════════════════════════════════════
     TOAST CONTAINER
══════════════════════════════════════════════════════════════════ -->
<div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer" style="z-index:9999;"></div>

<!-- ══════════════════════════════════════════════════════════════════
     LOADING OVERLAY
══════════════════════════════════════════════════════════════════ -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-box">
        <div class="spinner"></div>
        <p id="loadingMessage">Generating report…</p>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     DATA INJECTION — server-side JSON for JS consumption
══════════════════════════════════════════════════════════════════ -->
<script>
    window.studentsData = @Html.Raw(ViewBag.StudentsJson ?? "[]");
    window.schoolsData  = @Html.Raw(ViewBag.SchoolsJson  ?? "[]");
</script>

@Scripts.Render("~/Scripts/ReportsScript.js")
