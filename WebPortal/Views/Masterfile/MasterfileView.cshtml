@Styles.Render("~/Content/MasterfileStyles.css")

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Masterfile – LiteRise Portal</title>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════════════
     MASTERFILE PAGE WRAPPER
═══════════════════════════════════════════════════════════════════════ -->
<div class="masterfile-page">

    <!-- Page Header -->
    <div class="page-header d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="page-title mb-0">Masterfile</h2>
            <p class="text-muted small mb-0">Manage questions, lessons, badges, and administrators</p>
        </div>
    </div>

    <!-- ── Tab Navigation ──────────────────────────────────────────────── -->
    <ul class="masterfile-tabs nav mb-0" id="masterfileTabs">
        <li class="nav-item">
            <button class="tab-btn active" data-tab="questions">
                <i class="bi bi-question-circle me-1"></i> Question Bank
            </button>
        </li>
        <li class="nav-item">
            <button class="tab-btn" data-tab="modules">
                <i class="bi bi-journal-bookmark me-1"></i> Lessons &amp; Modules
            </button>
        </li>
        <li class="nav-item">
            <button class="tab-btn" data-tab="badges">
                <i class="bi bi-award me-1"></i> Badges
            </button>
        </li>
        <li class="nav-item">
            <button class="tab-btn" data-tab="admins">
                <i class="bi bi-people me-1"></i> Administrators
            </button>
        </li>
    </ul>

    <div class="tab-content-wrapper">

        <!-- ══════════════════════════════════════════════════════════════
             TAB 1 — QUESTION BANK
        ══════════════════════════════════════════════════════════════ -->
        <div class="tab-panel active" id="tab-questions">

            <!-- Toolbar -->
            <div class="toolbar d-flex flex-wrap align-items-center gap-2 mb-3">
                <button class="btn btn-primary-green" id="btnAddQuestion" onclick="openAddQuestion()">
                    <i class="bi bi-plus-lg me-1"></i> Add Question
                </button>
                <button class="btn btn-outline-secondary" id="btnImportCsv" onclick="triggerCsvImport()">
                    <i class="bi bi-upload me-1"></i> Import CSV
                </button>
                <input type="file" id="csvFileInput" accept=".csv" style="display:none" onchange="handleCsvImport(this)" />

                <input type="text" class="form-control search-input" id="questionSearch"
                       placeholder="Search questions…" oninput="filterQuestions()" />

                <select class="form-select filter-select" id="categoryFilter" onchange="filterQuestions()">
                    <option value="">All Categories</option>
                    <option value="Phonics">Phonics</option>
                    <option value="Vocabulary">Vocabulary</option>
                    <option value="Grammar">Grammar</option>
                    <option value="Comprehension">Comprehension</option>
                    <option value="Creating Text">Creating Text</option>
                </select>

                <select class="form-select filter-select" id="typeFilter" onchange="filterQuestions()">
                    <option value="">All Types</option>
                    <option value="Multiple Choice">Multiple Choice</option>
                    <option value="Pronunciation">Pronunciation</option>
                    <option value="Reading">Reading</option>
                </select>

                <button class="btn btn-outline-secondary ms-auto" onclick="exportQuestionsCsv()">
                    <i class="bi bi-download me-1"></i> Export CSV
                </button>
            </div>

            <!-- Questions Table -->
            <div class="card table-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="questionsTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Category</th>
                                    <th>Difficulty (b)</th>
                                    <th>Discrimination (a)</th>
                                    <th>Type</th>
                                    <th>Preview</th>
                                    <th>Active</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="questionsTableBody">
                                <tr>
                                    <td colspan="8" class="text-center py-4 text-muted">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                        Loading questions…
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Pagination -->
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <span class="text-muted small" id="questionsPaginationInfo">Showing 0–0 of 0</span>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" id="questionsPrevBtn" onclick="questionsPagePrev()" disabled>
                            <i class="bi bi-chevron-left"></i> Previous
                        </button>
                        <button class="btn btn-outline-secondary" id="questionsNextBtn" onclick="questionsPageNext()">
                            Next <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- /TAB 1 -->

        <!-- ══════════════════════════════════════════════════════════════
             TAB 2 — LESSONS & MODULES
        ══════════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="tab-modules">

            <div class="d-flex align-items-center mb-3">
                <h5 class="mb-0 me-3">Module Ladder</h5>
                <button class="btn btn-outline-secondary btn-sm" onclick="loadModules()">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
            </div>

            <div id="modulesAccordion" class="accordion">
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    Loading modules…
                </div>
            </div>
        </div>
        <!-- /TAB 2 -->

        <!-- ══════════════════════════════════════════════════════════════
             TAB 3 — BADGES
        ══════════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="tab-badges">

            <div class="toolbar d-flex align-items-center gap-2 mb-3">
                <button class="btn btn-primary-green" onclick="openAddBadge()">
                    <i class="bi bi-plus-lg me-1"></i> Add Badge
                </button>
            </div>

            <div id="badgesGrid" class="badges-grid">
                <div class="text-center py-5 text-muted w-100">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                    Loading badges…
                </div>
            </div>
        </div>
        <!-- /TAB 3 -->

        <!-- ══════════════════════════════════════════════════════════════
             TAB 4 — ADMINISTRATORS
        ══════════════════════════════════════════════════════════════ -->
        <div class="tab-panel" id="tab-admins">

            <div class="toolbar d-flex flex-wrap align-items-center gap-2 mb-3">
                <button class="btn btn-primary-green" onclick="openAddAdmin()">
                    <i class="bi bi-person-plus me-1"></i> Add Account
                </button>
                <input type="text" class="form-control search-input" id="adminSearch"
                       placeholder="Search by name or email…" oninput="filterAdmins()" />
                <select class="form-select filter-select" id="adminRoleFilter" onchange="filterAdmins()">
                    <option value="">All Roles</option>
                    <option value="Admin">Admin</option>
                    <option value="Teacher">Teacher</option>
                </select>
            </div>

            <div class="card table-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="adminsTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>School</th>
                                    <th>Last Login</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="adminsTableBody">
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">
                                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                        Loading administrators…
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <!-- /TAB 4 -->

    </div><!-- /tab-content-wrapper -->
</div><!-- /masterfile-page -->


<!-- ═══════════════════════════════════════════════════════════════════════
     MODALS
═══════════════════════════════════════════════════════════════════════ -->

<!-- ── Add / Edit Question Modal ────────────────────────────────────── -->
<div class="modal fade" id="questionModal" tabindex="-1" aria-labelledby="questionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="questionModalLabel">Add Question</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="qId" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Category</label>
                        <select class="form-select" id="qCategory">
                            <option value="">— Select —</option>
                            <option value="Phonics">Phonics</option>
                            <option value="Vocabulary">Vocabulary</option>
                            <option value="Grammar">Grammar</option>
                            <option value="Comprehension">Comprehension</option>
                            <option value="Creating Text">Creating Text</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Type</label>
                        <select class="form-select" id="qType">
                            <option value="">— Select —</option>
                            <option value="Multiple Choice">Multiple Choice</option>
                            <option value="Pronunciation">Pronunciation</option>
                            <option value="Reading">Reading</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Difficulty (b) <span class="text-muted small">-3 to 3</span></label>
                        <input type="number" class="form-control" id="qDifficulty" min="-3" max="3" step="0.01" placeholder="e.g. 0.5" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Discrimination (a) <span class="text-muted small">0.5 to 3</span></label>
                        <input type="number" class="form-control" id="qDiscrimination" min="0.5" max="3" step="0.01" placeholder="e.g. 1.2" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Question Text</label>
                        <textarea class="form-control" id="qText" rows="3" placeholder="Enter the question…"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Choice A</label>
                        <input type="text" class="form-control" id="qChoiceA" placeholder="Option A" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Choice B</label>
                        <input type="text" class="form-control" id="qChoiceB" placeholder="Option B" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Choice C</label>
                        <input type="text" class="form-control" id="qChoiceC" placeholder="Option C" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Choice D</label>
                        <input type="text" class="form-control" id="qChoiceD" placeholder="Option D" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold d-block">Correct Answer</label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="qCorrect" id="qCorrectA" value="A" />
                                <label class="form-check-label" for="qCorrectA">A</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="qCorrect" id="qCorrectB" value="B" />
                                <label class="form-check-label" for="qCorrectB">B</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="qCorrect" id="qCorrectC" value="C" />
                                <label class="form-check-label" for="qCorrectC">C</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="qCorrect" id="qCorrectD" value="D" />
                                <label class="form-check-label" for="qCorrectD">D</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="qActive" checked />
                            <label class="form-check-label fw-semibold" for="qActive">Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary-green" onclick="saveQuestion()">
                    <i class="bi bi-check-lg me-1"></i> Save Question
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── CSV Import Preview Modal ──────────────────────────────────────── -->
<div class="modal fade" id="csvPreviewModal" tabindex="-1" aria-labelledby="csvPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="csvPreviewModalLabel">CSV Import Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Review the rows below before confirming the import.</p>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered mb-0" id="csvPreviewTable">
                        <thead id="csvPreviewHead"></thead>
                        <tbody id="csvPreviewBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <span class="text-muted small me-auto" id="csvPreviewCount"></span>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary-green" onclick="confirmCsvImport()">
                    <i class="bi bi-check-lg me-1"></i> Confirm Import
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Node Preview Modal ────────────────────────────────────────────── -->
<div class="modal fade" id="nodePreviewModal" tabindex="-1" aria-labelledby="nodePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="nodePreviewModalLabel">Node Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="nodePreviewBody">
                <!-- filled dynamically -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- ── Add / Edit Badge Modal ────────────────────────────────────────── -->
<div class="modal fade" id="badgeModal" tabindex="-1" aria-labelledby="badgeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="badgeModalLabel">Add Badge</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="bId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Badge Icon (emoji)</label>
                        <input type="text" class="form-control" id="bIcon" placeholder="e.g. 🏆" maxlength="4" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Name</label>
                        <input type="text" class="form-control" id="bName" placeholder="Badge name" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" id="bDescription" rows="2" placeholder="Short description…"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Category</label>
                        <select class="form-select" id="bCategory">
                            <option value="">— Select —</option>
                            <option value="Module">Module</option>
                            <option value="XP">XP</option>
                            <option value="Streak">Streak</option>
                            <option value="Achievement">Achievement</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">XP Reward</label>
                        <input type="number" class="form-control" id="bXpReward" min="0" placeholder="e.g. 50" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Criteria</label>
                        <textarea class="form-control" id="bCriteria" rows="2" placeholder="Describe how this badge is earned…"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary-green" onclick="saveBadge()">
                    <i class="bi bi-check-lg me-1"></i> Save Badge
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Add / Edit Admin Modal ────────────────────────────────────────── -->
<div class="modal fade" id="adminModal" tabindex="-1" aria-labelledby="adminModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="adminModalLabel">Add Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="aId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input type="text" class="form-control" id="aName" placeholder="e.g. Maria Santos" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" class="form-control" id="aEmail" placeholder="name@domain.com" />
                    </div>
                    <div class="col-12" id="aPasswordGroup">
                        <label class="form-label fw-semibold">Password</label>
                        <input type="password" class="form-control" id="aPassword" placeholder="Set a password" autocomplete="new-password" />
                        <div class="form-text">Leave blank to keep existing password when editing.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Role</label>
                        <select class="form-select" id="aRole" onchange="handleAdminRoleChange()">
                            <option value="">— Select —</option>
                            <option value="Admin">Admin</option>
                            <option value="Teacher">Teacher</option>
                        </select>
                    </div>
                    <div class="col-12" id="aSchoolGroup" style="display:none">
                        <label class="form-label fw-semibold">School</label>
                        <select class="form-select" id="aSchool">
                            <option value="">— Select School —</option>
                            <option value="Pag-asa Elementary School">Pag-asa Elementary School</option>
                            <option value="Mabini Central Elementary School">Mabini Central Elementary School</option>
                            <option value="Rizal National Elementary School">Rizal National Elementary School</option>
                            <option value="Bonifacio Elementary School">Bonifacio Elementary School</option>
                            <option value="Luna Elementary School">Luna Elementary School</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary-green" onclick="saveAdmin()">
                    <i class="bi bi-check-lg me-1"></i> Save Account
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Toast Container ───────────────────────────────────────────────── -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index:9999">
</div>

@Scripts.Render("~/Scripts/MasterfileScript.js")
</body>
</html>
