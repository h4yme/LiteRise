@inherits System.Web.Mvc.WebViewPage
@{
    var userName = Session["UserName"]?.ToString() ?? "User";
    var userEmail = Session["UserEmail"]?.ToString() ?? "";
    var userRole = Session["UserRole"]?.ToString() ?? "admin";
    var isAdmin = userRole == "admin";
    // Initials from name
    var parts = userName.Split(new[] { ' ' }, System.StringSplitOptions.RemoveEmptyEntries);
    var initials = parts.Length >= 2
        ? parts[0].Substring(0, 1).ToUpper() + parts[parts.Length - 1].Substring(0, 1).ToUpper()
        : userName.Substring(0, Math.Min(2, userName.Length)).ToUpper();
    // Determine current page for active sidebar item
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var activeMap = new System.Collections.Generic.Dictionary<string, string>
    {
        { "Dashboard",          "Dashboard" },
        { "Student",            "Students" },
        { "Schools",            "Schools" },
        { "Masterfile",         "Masterfile" },
        { "Analytics",          "Analytics" },
        { "Administration",     "Administration" },
        { "Reports",            "Reports" },
        { "Notifications",      "Notifications" },
        { "Settings",           "Settings" },
        { "TeacherDashboard",   "Dashboard" },
        { "TeacherStudents",    "Students" },
        { "TeacherAnalytics",   "TeacherAnalytics" },
        { "TeacherReports",     "TeacherReports" },
        { "TeacherSettings",    "TeacherSettings" },
    };
    var activePage = activeMap.ContainsKey(controller) ? activeMap[controller] : "";
    // Dashboard / students / settings URLs by role
    var dashUrl     = isAdmin ? Url.Action("Index", "Dashboard")       : Url.Action("Index", "TeacherDashboard");
    var studentsUrl = isAdmin ? Url.Action("Index", "Student")         : Url.Action("Index", "TeacherStudents");
    var settingsUrl = isAdmin ? Url.Action("Index", "Settings")        : Url.Action("Index", "TeacherSettings");
}
