             body, input, button, label, p, h1, h2, h3, h4, h5, h6, a, span, div, select, textarea {
                 font-family: 'Visby',sans-serif
             }
             :root {
                 --green: #11B067;
                 --green-dark: #0EA05A;
                 --green-light: #84C788;
                 --green-pale: #E8F7EE;
                 --yellow: #FDC94A;
                 --yellow-pale: #FFF8E6;
                 --purple: #7C3AED;
                 --purple-pale: #F3EEFF;
                 --orange: #F97316;
                 --orange-pale: #FFF4ED;
                 --teal: #14B8A6;
                 --teal-pale: #F0FDFB;
                 --red: #EF4444;
                 --red-pale: #FEE2E2;
                 --dark: #0F172A;
                 --dark-card: #1E293B;
                 --dark-muted: #334155;
                 --text: #0F172A;
                 --text-secondary: #64748B;
                 --text-muted: #94A3B8;
                 --bg: #F8FAFC;
                 --bg-white: #FFFFFF;
                 --border: #E2E8F0;
                 --border-light: rgba(226,232,240,0.6);
                 --grad-green: linear-gradient(135deg,#0EA05A 0%,#11B067 60%,#22C55E 100%);
                 --grad-yellow: linear-gradient(135deg,#F59E0B 0%,#FDC94A 100%);
                 --grad-sidebar: linear-gradient(180deg,#0F172A 0%,#1E293B 100%);
                 --shadow-xs: 0 1px 3px rgba(15,23,42,0.08);
                 --shadow-sm: 0 4px 6px rgba(15,23,42,0.07);
                 --shadow-md: 0 10px 25px rgba(15,23,42,0.1);
                 --shadow-lg: 0 20px 50px rgba(15,23,42,0.14);
                 --shadow-green: 0 8px 24px rgba(17,176,103,0.3);
                 --radius-sm: 8px;
                 --radius-md: 12px;
                 --radius-lg: 16px;
                 --radius-xl: 20px;
                 --radius-pill: 999px;
             }
             *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
             body {
                 font-family: 'Visby',sans-serif;
                 background: var(--bg);
                 color: var(--text);
                 min-height: 100vh;
                 -webkit-font-smoothing: antialiased;
                 overflow-x: hidden
             }
             body.dark-mode {
                 --bg: #0D1117;
                 --bg-white: #161B22;
                 --border: rgba(255,255,255,0.08);
                 --text: #E2E8F0;
                 --text-secondary: #94A3B8
             }
             .background-bubbles { display: none }
             /* Theme toggle */
             .theme-toggle {
                 position: fixed; bottom: 28px; right: 28px;
                 width: 44px; height: 44px; border-radius: 50%;
                 background: var(--bg-white); border: 1px solid var(--border);
                 box-shadow: var(--shadow-md); cursor: pointer;
                 display: flex; align-items: center; justify-content: center;
                 transition: all 0.2s; z-index: 100
             }
             .theme-toggle:hover { transform: scale(1.08); box-shadow: var(--shadow-lg) }
             .theme-toggle svg { width: 20px; height: 20px; transition: all 0.3s }
             .theme-toggle .sun-icon { display: none; color: var(--yellow) }
             .theme-toggle .moon-icon { display: block; color: var(--dark-muted) }
             body.dark-mode .theme-toggle .sun-icon { display: block }
             body.dark-mode .theme-toggle .moon-icon { display: none }
             body.dark-mode .theme-toggle { background: var(--dark-card); border-color: rgba(255,255,255,0.1) }
             /* Top Bar */
             .TopBar {
                 background: var(--bg-white); border-bottom: 1px solid var(--border);
                 color: var(--text); position: fixed; top: 0; left: 0; right: 0;
                 z-index: 1001; height: 60px; display: flex; align-items: center;
                 justify-content: space-between; padding: 0 20px;
                 box-shadow: var(--shadow-xs); transition: background 0.3s,border-color 0.3s
             }
             body.dark-mode .TopBar { background: var(--dark-card); border-bottom-color: rgba(255,255,255,0.08) }
             .topbar-left { display: flex; align-items: center; gap: 14px }
             .sidebar-toggle {
                 background: transparent; border: none; cursor: pointer; padding: 8px;
                 display: flex; align-items: center; justify-content: center;
                 border-radius: var(--radius-sm); transition: background 0.2s;
                 width: 36px; height: 36px; color: var(--text-secondary)
             }
             .sidebar-toggle:hover { background: var(--green-pale); color: var(--green) }
             body.dark-mode .sidebar-toggle:hover { background: rgba(17,176,103,0.12) }
             .sidebar-toggle svg { width: 18px; height: 18px }
             .topbar-brand {
                 color: var(--text); text-decoration: none; font-size: 1.15rem;
                 font-weight: 800; letter-spacing: -0.3px; transition: color 0.2s
             }
             .topbar-brand:hover { color: var(--green); text-decoration: none }
             body.dark-mode .topbar-brand { color: #fff }
             .topbar-right { display: flex; align-items: center; gap: 6px }
             .topbar-icon-btn {
                 background: transparent; border: none; cursor: pointer; padding: 8px;
                 display: flex; align-items: center; justify-content: center;
                 border-radius: var(--radius-sm); transition: background 0.2s;
                 position: relative; width: 36px; height: 36px; color: var(--text-secondary)
             }
             .topbar-icon-btn:hover { background: var(--green-pale); color: var(--green) }
             body.dark-mode .topbar-icon-btn:hover { background: rgba(17,176,103,0.12); color: var(--green-light) }
             .topbar-icon-btn .glyphicon { font-size: 16px }
             .dropdown-container { position: relative }
             .notification-badge {
                 position: absolute; top: 4px; right: 4px; background: var(--red);
                 color: #fff; font-size: 9px; font-weight: 700; border-radius: 50%;
                 width: 16px; height: 16px; display: flex; align-items: center; justify-content: center
             }
             /* Sidebar */
             .Sidebar {
                 position: fixed; top: 60px; left: 0; bottom: 0; width: 240px;
                 background: var(--dark); z-index: 1000; transition: width 0.3s ease;
                 display: flex; flex-direction: column; overflow: hidden;
                 box-shadow: 2px 0 16px rgba(0,0,0,0.2)
             }
             body.dark-mode .Sidebar { background: #0D1117 }
             .Sidebar.no-transition, .Sidebar.no-transition ~ .Main-Container { transition: none !important }
             .Sidebar.collapsed { width: 60px }
             .sidebar-content { display: flex; flex-direction: column; height: 100%; padding: 12px 0 }
             .sidebar-nav { flex: 1; overflow-y: auto; overflow-x: hidden }
             .sidebar-nav::-webkit-scrollbar { width: 4px }
             .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px }
             .sidebar-nav-item {
                 display: flex; align-items: center; gap: 12px; padding: 10px 14px;
                 color: rgba(255,255,255,0.55); text-decoration: none; transition: all 0.2s;
                 white-space: nowrap; margin: 2px 8px; border-radius: var(--radius-md);
                 min-height: 42px; font-size: 0.9rem; font-weight: 500
             }
             .sidebar-nav-item:hover { background: rgba(17,176,103,0.12); color: var(--green-light); text-decoration: none }
             .sidebar-nav-item.active {
                 background: rgba(17,176,103,0.18); color: #fff; font-weight: 600;
                 border-left: 3px solid var(--green); padding-left: 11px
             }
             .Sidebar.collapsed .sidebar-nav-item {
                 justify-content: center; padding: 12px 0; margin: 2px 0;
                 gap: 0; border-radius: 0; border-left: none
             }
             .Sidebar.collapsed .sidebar-nav-item:hover { border-radius: 0 }
             .Sidebar.collapsed .sidebar-nav-item.active { background: rgba(17,176,103,0.18); border-left: 3px solid var(--green) }
             .sidebar-icon { flex-shrink: 0; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center }
             .sidebar-icon .glyphicon { font-size: 16px }
             .sidebar-text { opacity: 1; transition: opacity 0.25s }
             .Sidebar.collapsed .sidebar-text { opacity: 0; width: 0 }
             .sidebar-footer { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 12px }
             .sidebar-profile {
                 display: flex; align-items: center; gap: 10px; padding: 10px 14px;
                 color: rgba(255,255,255,0.55); text-decoration: none; transition: all 0.2s;
                 margin: 0 8px; border-radius: var(--radius-md); min-height: 52px
             }
             .sidebar-profile:hover { background: rgba(255,255,255,0.06); color: #fff; text-decoration: none }
             .Sidebar.collapsed .sidebar-profile { justify-content: center; padding: 12px 0; margin: 0; gap: 0; border-radius: 0 }
             .Sidebar.collapsed .sidebar-profile:hover { border-radius: 0 }
             .profile-avatar {
                 width: 32px; height: 32px; border-radius: 50%; background: var(--grad-green);
                 flex-shrink: 0; display: flex; align-items: center; justify-content: center;
                 color: #fff; font-weight: 700; font-size: 12px; box-shadow: 0 2px 8px rgba(17,176,103,0.4)
             }
             .profile-info { display: flex; flex-direction: column; opacity: 1; transition: opacity 0.25s; min-width: 0 }
             .Sidebar.collapsed .profile-info { opacity: 0; width: 0 }
             .profile-name { font-weight: 600; font-size: 0.85rem; color: rgba(255,255,255,0.85); white-space: nowrap; overflow: hidden; text-overflow: ellipsis }
             .profile-email { font-size: 0.72rem; color: rgba(255,255,255,0.35); white-space: nowrap; overflow: hidden; text-overflow: ellipsis }
             /* Main Content */
             .Main-Container {
                 margin-top: 60px; margin-left: 240px; transition: margin-left 0.3s ease;
                 min-height: calc(100vh - 60px); display: flex; flex-direction: column; background: var(--bg)
             }
             .Sidebar.collapsed ~ .Main-Container { margin-left: 60px }
             .Container-Body { flex: 1; padding: 28px; overflow-y: auto; overflow-x: hidden }
             /* Notifications Panel */
             .notifications-panel {
                 position: absolute; top: calc(100% + 8px); right: 0; width: 380px;
                 max-height: 480px; background: var(--bg-white); border: 1px solid var(--border);
                 border-radius: var(--radius-xl); box-shadow: var(--shadow-lg);
                 opacity: 0; visibility: hidden; transform: translateY(-8px);
                 transition: all 0.25s ease; z-index: 2000; overflow: hidden; display: flex; flex-direction: column
             }
             body.dark-mode .notifications-panel { background: var(--dark-card); border-color: rgba(255,255,255,0.08) }
             .notifications-panel.show { opacity: 1; visibility: visible; transform: translateY(0) }
             .notifications-header { padding: 16px 20px; border-bottom: 1px solid var(--border) }
             body.dark-mode .notifications-header { border-bottom-color: rgba(255,255,255,0.08) }
             .notifications-header h3 { margin: 0; font-size: 1rem; font-weight: 700; color: var(--text) }
             .notifications-list { overflow-y: auto; flex: 1 }
             .notification-item {
                 display: flex; align-items: flex-start; padding: 14px 20px; gap: 12px;
                 text-decoration: none; color: var(--text); transition: background 0.2s;
                 border-bottom: 1px solid var(--border-light)
             }
             body.dark-mode .notification-item { border-bottom-color: rgba(255,255,255,0.05) }
             .notification-item:last-child { border-bottom: none }
             .notification-item:hover { background: var(--bg); text-decoration: none }
             body.dark-mode .notification-item:hover { background: rgba(255,255,255,0.04) }
             .notification-item.unread { background: var(--green-pale) }
             body.dark-mode .notification-item.unread { background: rgba(17,176,103,0.08) }
             .notification-icon { flex-shrink: 0; width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px }
             .notification-icon.info { background: #DBEAFE; color: #3B82F6 }
             .notification-icon.success { background: var(--green-pale); color: var(--green) }
             .notification-icon.warning { background: var(--yellow-pale); color: #D97706 }
             .notification-icon.error { background: var(--red-pale); color: var(--red) }
             body.dark-mode .notification-icon.success { background: rgba(17,176,103,0.15) }
             .notification-content { flex: 1; min-width: 0 }
             .notification-text { font-size: 0.83rem; line-height: 1.5; margin-bottom: 3px; color: var(--text) }
             .notification-time { font-size: 0.72rem; color: var(--text-muted) }
             /* Settings Dropdown */
             .dropdown-menu {
                 position: absolute; top: calc(100% + 8px); right: 0;
                 background: var(--bg-white); border: 1px solid var(--border);
                 border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);
                 min-width: 190px; padding: 6px 0; opacity: 0; visibility: hidden;
                 transform: translateY(-8px); transition: all 0.25s ease; z-index: 2000
             }
             body.dark-mode .dropdown-menu { background: var(--dark-card); border-color: rgba(255,255,255,0.08) }
             .dropdown-menu.show { opacity: 1; visibility: visible; transform: translateY(0) }
             .dropdown-menu a {
                 display: flex; align-items: center; gap: 10px; padding: 10px 18px;
                 color: var(--text-secondary); text-decoration: none; transition: all 0.2s;
                 font-weight: 500; font-size: 0.88rem
             }
             .dropdown-menu a:hover { background: var(--green-pale); color: var(--green); text-decoration: none }
             body.dark-mode .dropdown-menu a { color: rgba(255,255,255,0.6) }
             body.dark-mode .dropdown-menu a:hover { background: rgba(17,176,103,0.1); color: var(--green-light) }
             .dropdown-menu a .glyphicon { font-size: 14px }
             .dropdown-divider { height: 1px; background: var(--border); margin: 6px 0 }
             body.dark-mode .dropdown-divider { background: rgba(255,255,255,0.07) }
             /* Logout Modal */
             .logout-modal {
                 display: none; position: fixed; z-index: 2500; inset: 0;
                 background: rgba(15,23,42,0.6); backdrop-filter: blur(4px);
                 align-items: center; justify-content: center; padding: 20px
             }
             .logout-modal.show { display: flex; animation: fadeIn 0.25s }
             @@keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }
             @@keyframes slideIn { from { transform: translateY(-24px); opacity: 0 } to { transform: translateY(0); opacity: 1 } }
             .logout-modal-content {
                 position: relative; background: var(--bg-white); padding: 40px;
                 width: 100%; max-width: 420px; border-radius: 24px; box-shadow: var(--shadow-lg);
                 text-align: center; animation: slideIn 0.25s; margin: auto
             }
             .logout-modal-close {
                 position: absolute; right: 18px; top: 18px; font-size: 28px; font-weight: 300;
                 color: var(--text-muted); background: none; border: none; cursor: pointer;
                 transition: color 0.2s; line-height: 1; width: 30px; height: 30px; padding: 0
             }
             .logout-modal-close:hover { color: var(--text) }
             .logout-modal-icon { display: flex; justify-content: center; margin-bottom: 18px }
             .logout-modal-icon svg { width: 72px; height: 72px }
             .logout-modal-content h2 { font-size: 1.35rem; font-weight: 700; color: var(--text); margin-bottom: 6px }
             .logout-modal-content p { font-size: 0.88rem; color: var(--text-secondary); margin-bottom: 28px }
             .logout-modal-buttons { display: flex; gap: 10px }
             .btn-logout-cancel, .btn-logout-confirm {
                 flex: 1; padding: 12px 20px; border: none; border-radius: var(--radius-md);
                 font-size: 0.95rem; font-weight: 700; font-family: 'Visby',sans-serif;
                 cursor: pointer; transition: all 0.2s
             }
             .btn-logout-cancel { background: var(--border); color: var(--text-secondary) }
             .btn-logout-cancel:hover { background: #CBD5E0; transform: translateY(-1px) }
             .btn-logout-confirm { background: linear-gradient(135deg,#EF4444,#DC2626); color: #fff; box-shadow: 0 4px 14px rgba(220,38,38,0.35) }
             .btn-logout-confirm:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(220,38,38,0.5) }
             /* Sidebar overlay (mobile) */
             .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999 }
             .sidebar-overlay.active { display: block }
             /* Responsive */
             @@media (max-width:768px) {
                 #sidebarToggle { display: none !important }
                 .mobile-toggle { display: flex !important }
                 .Sidebar { transform: translateX(-100%); width: 280px }
                 .Sidebar.mobile-open { transform: translateX(0) }
                 .Sidebar.collapsed { transform: translateX(-100%); width: 280px }
                 .Sidebar.collapsed.mobile-open { transform: translateX(0) }
                 .Main-Container { margin-left: 0 }
                 .Sidebar.collapsed ~ .Main-Container { margin-left: 0 }
                 .Container-Body { padding: 18px }
                 .notifications-panel { position: fixed; top: 60px; right: 10px; left: 10px; width: auto; max-height: calc(100vh - 80px) }
                 .dropdown-menu { position: fixed; right: 10px; top: 60px }
                 .theme-toggle { bottom: 18px; right: 18px; width: 40px; height: 40px }
             }
             @@media (min-width:769px) {
                 #sidebarToggle { display: flex !important }
                 .mobile-toggle { display: none !important }
             }
             @@media (max-width:480px) { .topbar-brand { font-size: 1rem } }
             /* ── LR Table (shared) ─────────────────────────────────────── */
             .lr-table { width: 100%; border-collapse: collapse; font-size: 0.88rem }
             .lr-table th { padding: 10px 14px; text-align: left; font-size: 0.78rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .5px; background: var(--bg); border-bottom: 2px solid var(--border) }
             .lr-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: middle }
             .lr-table tr:last-child td { border-bottom: none }
             .lr-table tr:hover td { background: var(--green-pale) }
             body.dark-mode .lr-table th { background: rgba(255,255,255,.04); color: #64748B; border-bottom-color: rgba(255,255,255,.08) }
             body.dark-mode .lr-table td { border-bottom-color: rgba(255,255,255,.06); color: #94A3B8 }
             body.dark-mode .lr-table tr:hover td { background: rgba(17,176,103,.06) }
             .student-link { color: var(--text); font-weight: 600; text-decoration: none }
             .student-link:hover { color: var(--green) }
             .level-badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.72rem; font-weight: 700; text-transform: capitalize }
             .level-badge.beginner { background: var(--purple-pale); color: var(--purple) }
             .level-badge.intermediate { background: var(--green-pale); color: var(--green) }
             .level-badge.advanced { background: var(--yellow-pale); color: #D97706 }
             .status-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 4px; background: #94A3B8 }
             .status-dot.active { background: var(--green) }
             .status-dot.inactive { background: #94A3B8 }
             .empty-state { text-align: center; color: var(--text-muted); padding: 28px; font-style: italic }
             .alert-banner { padding: 12px 16px; border-radius: 10px; margin-bottom: 20px; font-size: 0.88rem; font-weight: 600 }
             .alert-banner.error { background: var(--red-pale); color: #DC2626; border: 1px solid #FECACA }
             .alert-banner.success { background: var(--green-pale); color: var(--green); border: 1px solid #BBF7D0 }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Theme Toggle -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <svg class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5" stroke-width="2"></circle>
            <line x1="12" y1="1" x2="12" y2="3" stroke-width="2"></line>
            <line x1="12" y1="21" x2="12" y2="23" stroke-width="2"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke-width="2"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke-width="2"></line>
            <line x1="1" y1="12" x2="3" y2="12" stroke-width="2"></line>
            <line x1="21" y1="12" x2="23" y2="12" stroke-width="2"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke-width="2"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke-width="2"></line>
        </svg>
        <svg class="moon-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
    </button>

    <!-- ══ TOP BAR ══════════════════════════════════════════════ -->
    <div class="TopBar">
        <div class="topbar-left">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
            <button class="sidebar-toggle mobile-toggle" id="mobileSidebarToggle" aria-label="Open menu">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
            <a href="@dashUrl" class="topbar-brand">LiteRise</a>
        </div>
        <div class="topbar-right">
            <!-- Notifications -->
            <div class="dropdown-container">
                <button class="topbar-icon-btn" id="notificationsToggle"
                        aria-label="Notifications" aria-expanded="false">
                    <span class="glyphicon glyphicon-bell"></span>
                    <span class="notification-badge">5</span>
                </button>
                <div class="notifications-panel" id="notificationsPanel">
                    <div class="notifications-header"><h3>Notifications</h3></div>
                    <div class="notifications-list">
                        <div class="notification-item unread">
                            <div class="notification-icon info">
                                <span class="glyphicon glyphicon-info-sign"></span>
                            </div>
                            <div class="notification-content">
                                <div class="notification-text">Welcome to LiteRise Portal</div>
                                <div class="notification-time">Just now</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Settings -->
            <div class="dropdown-container">
                <button class="topbar-icon-btn" id="settingsToggle"
                        aria-label="Settings" aria-expanded="false">
                    <span class="glyphicon glyphicon-cog"></span>
                </button>
                <div class="dropdown-menu" id="settingsDropdown">
                    <div style="padding:12px 16px;border-bottom:1px solid #E2E8F0;">
                        <div style="font-weight:700;font-size:.88rem;">@userName</div>
                        <div style="font-size:.78rem;color:#64748B;">@userEmail</div>
                        <span style="font-size:.72rem;padding:2px 8px;background:#E8F7EE;color:#11B067;border-radius:999px;font-weight:700;">@userRole.ToUpper()</span>
                    </div>
                    <a href="@settingsUrl">
                        <span class="glyphicon glyphicon-cog"></span> Settings
                    </a>
                    <div class="dropdown-divider"></div>
                    <a href="javascript:void(0);" id="logoutLink">
                        <span class="glyphicon glyphicon-log-out"></span> Log out
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════ -->
    <div class="Sidebar" id="sidebar">
        <div class="sidebar-content">
            <nav class="sidebar-nav">
                <!-- ── Common: Dashboard ───────────────────────────────── -->
                <a href="@dashUrl"
                   class="sidebar-nav-item @(activePage == "Dashboard" ? "active" : "")"
                   data-page="Dashboard" title="Dashboard">
                    <div class="sidebar-icon"><span class="glyphicon glyphicon-dashboard"></span></div>
                    <span class="sidebar-text">Dashboard</span>
                </a>

                <!-- ── Common: Students / My Students ─────────────────── -->
                <a href="@studentsUrl"
                   class="sidebar-nav-item @(activePage == "Students" ? "active" : "")"
                   data-page="Students" title="@(isAdmin ? "Students" : "My Students")">
                    <div class="sidebar-icon"><span class="glyphicon glyphicon-education"></span></div>
                    <span class="sidebar-text">@(isAdmin ? "Students" : "My Students")</span>
                </a>

                @if (isAdmin)
                {
                    <!-- ── Admin-only nav items ───────────────────────── -->
                    <a href="@Url.Action("Index", "Schools")"
                       class="sidebar-nav-item @(activePage == "Schools" ? "active" : "")"
                       data-page="Schools" title="Schools">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-home"></span></div>
                        <span class="sidebar-text">Schools</span>
                    </a>
                    <a href="@Url.Action("Index", "Masterfile")"
                       class="sidebar-nav-item @(activePage == "Masterfile" ? "active" : "")"
                       data-page="Masterfile" title="Masterfile">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-folder-open"></span></div>
                        <span class="sidebar-text">Masterfile</span>
                    </a>
                    <a href="@Url.Action("Index", "Analytics")"
                       class="sidebar-nav-item @(activePage == "Analytics" ? "active" : "")"
                       data-page="Analytics" title="Analytics">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-stats"></span></div>
                        <span class="sidebar-text">Analytics</span>
                    </a>
                    <a href="@Url.Action("Index", "Reports")"
                       class="sidebar-nav-item @(activePage == "Reports" ? "active" : "")"
                       data-page="Reports" title="Reports">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-list-alt"></span></div>
                        <span class="sidebar-text">Reports</span>
                    </a>
                    <a href="@Url.Action("Index", "Notifications")"
                       class="sidebar-nav-item @(activePage == "Notifications" ? "active" : "")"
                       data-page="Notifications" title="Notifications">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-bell"></span></div>
                        <span class="sidebar-text">Notifications</span>
                    </a>
                    <a href="@Url.Action("Index", "Administration")"
                       class="sidebar-nav-item @(activePage == "Administration" ? "active" : "")"
                       data-page="Administration" title="Administration">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-user"></span></div>
                        <span class="sidebar-text">Administration</span>
                    </a>
                    <a href="@Url.Action("Index", "Settings")"
                       class="sidebar-nav-item @(activePage == "Settings" ? "active" : "")"
                       data-page="Settings" title="Settings">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-cog"></span></div>
                        <span class="sidebar-text">Settings</span>
                    </a>
                }
                else
                {
                    <!-- ── Teacher-only nav items ─────────────────────── -->
                    <a href="@Url.Action("Index", "TeacherAnalytics")"
                       class="sidebar-nav-item @(activePage == "TeacherAnalytics" ? "active" : "")"
                       data-page="TeacherAnalytics" title="Class Analytics">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-stats"></span></div>
                        <span class="sidebar-text">Analytics</span>
                    </a>
                    <a href="@Url.Action("Index", "TeacherReports")"
                       class="sidebar-nav-item @(activePage == "TeacherReports" ? "active" : "")"
                       data-page="TeacherReports" title="Progress Reports">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-list-alt"></span></div>
                        <span class="sidebar-text">Reports</span>
                    </a>
                    <a href="@Url.Action("Index", "TeacherSettings")"
                       class="sidebar-nav-item @(activePage == "TeacherSettings" ? "active" : "")"
                       data-page="TeacherSettings" title="Settings">
                        <div class="sidebar-icon"><span class="glyphicon glyphicon-cog"></span></div>
                        <span class="sidebar-text">Settings</span>
                    </a>
                }
            </nav>
            <div class="sidebar-footer">
                <div class="sidebar-profile">
                    <div class="profile-avatar">@initials</div>
                    <div class="profile-info">
                        <div class="profile-name">@userName</div>
                        <div class="profile-email">@userRole.ToUpper()</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ MAIN CONTENT ═════════════════════════════════════════ -->
    <div class="Main-Container">
        <div class="Container-Body">
            @RenderBody()
        </div>
    </div>

    @RenderSection("modals", required: false)
    @RenderSection("scripts", required: false)

    <script>
    (function () {
        'use strict';
        // ── Theme ──────────────────────────────────────────────────
        var themeToggle = document.getElementById('themeToggle');
        var savedTheme  = localStorage.getItem('lr-theme');
        if (savedTheme === 'dark') document.body.classList.add('dark-mode');
        if (themeToggle) {
            themeToggle.addEventListener('click', function () {
                document.body.classList.toggle('dark-mode');
                localStorage.setItem('lr-theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
            });
        }
        // ── Sidebar toggle ─────────────────────────────────────────
        var sidebar       = document.getElementById('sidebar');
        var sidebarToggle = document.getElementById('sidebarToggle');
        var collapsed     = localStorage.getItem('lr-sidebar') === 'collapsed';
        function applySidebarState() {
            if (collapsed) { document.body.classList.add('sidebar-collapsed'); sidebar && sidebar.classList.add('collapsed'); }
            else            { document.body.classList.remove('sidebar-collapsed'); sidebar && sidebar.classList.remove('collapsed'); }
        }
        applySidebarState();
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', function () {
                collapsed = !collapsed;
                localStorage.setItem('lr-sidebar', collapsed ? 'collapsed' : 'expanded');
                applySidebarState();
            });
        }
        // ── Mobile sidebar overlay ─────────────────────────────────
        var mobileToggle = document.getElementById('mobileSidebarToggle');
        var overlay      = document.createElement('div');
        overlay.className = 'sidebar-overlay';
        document.body.appendChild(overlay);
        function openMobileSidebar()  { sidebar && sidebar.classList.add('mobile-open');    overlay.classList.add('active'); }
        function closeMobileSidebar() { sidebar && sidebar.classList.remove('mobile-open'); overlay.classList.remove('active'); }
        if (mobileToggle) mobileToggle.addEventListener('click', openMobileSidebar);
        overlay.addEventListener('click', closeMobileSidebar);
        // ── Dropdowns ──────────────────────────────────────────────
        function setupDropdown(toggleId, panelId) {
            var btn   = document.getElementById(toggleId);
            var panel = document.getElementById(panelId);
            if (!btn || !panel) return;
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = panel.classList.contains('show');
                closeAllDropdowns();
                if (!isOpen) { panel.classList.add('show'); btn.setAttribute('aria-expanded', 'true'); }
            });
        }
        function closeAllDropdowns() {
            ['notificationsPanel','settingsDropdown'].forEach(function(id){
                var el = document.getElementById(id);
                if (el) el.classList.remove('show');
            });
            ['notificationsToggle','settingsToggle'].forEach(function(id){
                var el = document.getElementById(id);
                if (el) el.setAttribute('aria-expanded','false');
            });
        }
        setupDropdown('notificationsToggle', 'notificationsPanel');
        setupDropdown('settingsToggle', 'settingsDropdown');
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.dropdown-container')) closeAllDropdowns();
        });
        // ── Logout confirmation ────────────────────────────────────
        var logoutLink = document.getElementById('logoutLink');
        var LOGOUT_URL = '@Url.Action("Logout", "Login")';
        if (logoutLink) {
            logoutLink.addEventListener('click', function (e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Log Out',
                    text: 'Are you sure you want to log out?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#DC2626',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Yes, Log Out',
                    cancelButtonText: 'Cancel'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        window.location.href = LOGOUT_URL || '/Login/Logout';
                    }
                });
            });
        }
    })();
    </script>
</body>
</html>
