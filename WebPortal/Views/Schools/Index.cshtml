@{
    ViewBag.Title = "Schools";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<style>
    .page-subtitle { color: var(--text-secondary); font-size: 0.85rem }

    .filter-bar {
        background: var(--bg-white); border: 1px solid var(--border);
        border-radius: var(--radius-lg); padding: 16px 20px;
        margin-bottom: 16px; display: flex; align-items: center;
        flex-wrap: wrap; gap: 12px; box-shadow: var(--shadow-xs)
    }
    body.dark-mode .filter-bar { background: var(--dark-card); border-color: rgba(255,255,255,0.08) }
    .filter-bar label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); margin: 0 }
    .filter-bar select {
        padding: 7px 12px; border: 1px solid var(--border); border-radius: var(--radius-md);
        font-size: 0.85rem; background: var(--bg); color: var(--text); min-width: 160px
    }
    .filter-bar select:focus { outline: none; border-color: var(--green) }
    body.dark-mode .filter-bar select { background: var(--dark-card); border-color: rgba(255,255,255,0.1); color: var(--text) }
    .btn-reset {
        padding: 7px 16px; border-radius: var(--radius-md); font-size: 0.85rem;
        font-weight: 600; border: 1px solid var(--border);
        background: var(--bg); color: var(--text-secondary); cursor: pointer; transition: all 0.2s
    }
    .btn-reset:hover { background: var(--green-pale); color: var(--green); border-color: var(--green) }

    .schools-panel {
        background: var(--bg-white); border: 1px solid var(--border);
        border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-xs)
    }
    body.dark-mode .schools-panel { background: var(--dark-card); border-color: rgba(255,255,255,0.08) }
    .panel-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 10px
    }
    body.dark-mode .panel-toolbar { border-bottom-color: rgba(255,255,255,0.08) }
    .panel-toolbar input[type=text] {
        padding: 7px 12px; border: 1px solid var(--border); border-radius: var(--radius-md);
        font-size: 0.85rem; background: var(--bg); color: var(--text); width: 220px
    }
    .panel-toolbar input[type=text]:focus { outline: none; border-color: var(--green) }
    body.dark-mode .panel-toolbar input[type=text] { background: var(--dark-muted); border-color: rgba(255,255,255,0.1); color: var(--text) }
    .toolbar-right { display: flex; gap: 8px }
    .btn-add {
        padding: 8px 16px; border-radius: var(--radius-md); font-size: 0.85rem; font-weight: 700;
        background: var(--green); color: #fff; border: none; cursor: pointer; transition: background 0.2s
    }
    .btn-add:hover { background: var(--green-dark) }
    .btn-export {
        padding: 8px 16px; border-radius: var(--radius-md); font-size: 0.85rem; font-weight: 600;
        background: var(--bg-white); color: var(--text-secondary); border: 1px solid var(--border);
        cursor: pointer; transition: all 0.2s
    }
    .btn-export:hover { background: var(--green-pale); color: var(--green) }

    .schools-table { width: 100%; border-collapse: collapse; font-size: 0.88rem }
    .schools-table th {
        padding: 10px 14px; text-align: left; font-size: 0.75rem; font-weight: 700;
        color: var(--text-muted); text-transform: uppercase; letter-spacing: .5px;
        background: var(--bg); border-bottom: 2px solid var(--border);
        cursor: pointer; user-select: none; white-space: nowrap
    }
    .schools-table th:hover { color: var(--green) }
    body.dark-mode .schools-table th { background: rgba(255,255,255,.04); color: #64748B; border-bottom-color: rgba(255,255,255,.08) }
    .schools-table td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text-secondary); vertical-align: middle }
    .schools-table tr:last-child td { border-bottom: none }
    .schools-table tr:hover td { background: var(--green-pale) }
    body.dark-mode .schools-table td { border-bottom-color: rgba(255,255,255,.06); color: #94A3B8 }
    body.dark-mode .schools-table tr:hover td { background: rgba(17,176,103,.06) }
    .school-name { font-weight: 700; color: var(--text) }
    .district-badge {
        display: inline-block; padding: 2px 8px; background: var(--green-pale);
        color: var(--green); border-radius: 4px; font-size: 0.75rem; font-weight: 700
    }
    .pct-bar-wrap { display: flex; align-items: center; gap: 8px }
    .pct-bar-track { flex: 1; height: 6px; background: var(--border); border-radius: 3px; max-width: 100px }
    .pct-bar-fill  { height: 6px; background: var(--green); border-radius: 3px }
    .actions-btn {
        background: none; border: none; cursor: pointer; color: var(--text-muted);
        padding: 4px 8px; border-radius: var(--radius-sm); font-size: 1.2rem; line-height: 1
    }
    .actions-btn:hover { background: var(--border); color: var(--text) }

    /* Actions dropdown */
    .dd-actions {
        position: fixed; background: var(--bg-white); border: 1px solid var(--border);
        border-radius: var(--radius-md); box-shadow: var(--shadow-md);
        z-index: 300; min-width: 120px; overflow: hidden; display: none
    }
    body.dark-mode .dd-actions { background: var(--dark-card); border-color: rgba(255,255,255,0.1) }
    .dd-actions.open { display: block }
    .dd-actions a {
        display: flex; align-items: center; gap: 8px; padding: 9px 14px;
        font-size: 0.85rem; color: var(--text-secondary); text-decoration: none; transition: background 0.2s
    }
    .dd-actions a:hover { background: var(--green-pale); color: var(--green) }
    .dd-actions a.danger:hover { background: var(--red-pale); color: var(--red) }
    .empty-state { text-align: center; color: var(--text-muted); padding: 32px; font-style: italic }

    /* Modal */
    .modal-overlay {
        display: none; position: fixed; inset: 0; background: rgba(15,23,42,0.55);
        z-index: 2000; align-items: center; justify-content: center; padding: 20px
    }
    .modal-overlay.open { display: flex }
    .modal-box {
        background: var(--bg-white); border-radius: var(--radius-xl);
        box-shadow: var(--shadow-lg); width: 100%; max-width: 480px; padding: 28px;
        animation: slideIn 0.2s
    }
    body.dark-mode .modal-box { background: var(--dark-card) }
    @@keyframes slideIn { from { transform: translateY(-20px); opacity:0 } to { transform: translateY(0); opacity:1 } }
    .modal-box h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 20px; color: var(--text) }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px }
    .form-group { margin-bottom: 14px }
    .form-group label { display: block; font-size: 0.82rem; font-weight: 700; margin-bottom: 5px; color: var(--text) }
    .form-group input, .form-group select {
        width: 100%; padding: 9px 12px; border: 1px solid var(--border);
        border-radius: var(--radius-md); font-size: 0.88rem; background: var(--bg); color: var(--text)
    }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--green) }
    body.dark-mode .form-group input, body.dark-mode .form-group select { background: var(--dark-muted); border-color: rgba(255,255,255,0.1); color: var(--text) }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px }
    .btn-cancel {
        padding: 9px 20px; border-radius: var(--radius-md); font-size: 0.88rem;
        font-weight: 600; border: 1px solid var(--border);
        background: var(--bg); color: var(--text-secondary); cursor: pointer
    }
    .btn-save {
        padding: 9px 20px; border-radius: var(--radius-md); font-size: 0.88rem;
        font-weight: 700; background: var(--green); color: #fff; border: none; cursor: pointer
    }
    .btn-save:hover { background: var(--green-dark) }
    .btn-save:disabled { opacity: 0.6; cursor: not-allowed }
</style>
}

<div>
    <div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1"><i class="fas fa-school me-2 text-success"></i>School List</h2>
            <p class="page-subtitle mb-0">Manage schools and view student information</p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert-banner error" style="margin-bottom:16px;">@ViewBag.Error</div>
    }

    <!-- Filter Bar -->
    <div class="filter-bar">
        <label>District:</label>
        <select id="districtFilter" onchange="filterSchools()">
            <option value="">All Districts</option>
        </select>
        <label style="margin-left:8px;">City:</label>
        <select id="cityFilter" onchange="filterSchools()">
            <option value="">All Cities</option>
        </select>
        <button class="btn-reset" onclick="resetFilters()">Reset Filters</button>
    </div>

    <!-- Schools Panel -->
    <div class="schools-panel">
        <div class="panel-toolbar">
            <input type="text" id="searchInput" placeholder="Search schools…" oninput="filterSchools()" />
            <div class="toolbar-right">
                <button class="btn-add" onclick="openSchoolModal()">+ Add New School</button>
                <button class="btn-export" onclick="window.location.href='/Schools/ExportCsv'">Export to CSV</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="schools-table">
                <thead>
                    <tr>
                        <th onclick="sortBy('school_name')">School Name <span id="srt_school_name"> ▲</span></th>
                        <th onclick="sortBy('district')">District <span id="srt_district"></span></th>
                        <th onclick="sortBy('city')">City <span id="srt_city"></span></th>
                        <th onclick="sortBy('province')">Province <span id="srt_province"></span></th>
                        <th onclick="sortBy('pct')">% of Total Students <span id="srt_pct"></span></th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="schoolsTbody">
                    <tr><td colspan="6" class="empty-state">Loading…</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add / Edit School Modal -->
<div class="modal-overlay" id="schoolModal">
    <div class="modal-box">
        <h3 id="modalTitle"><i class="fas fa-school me-2 text-success"></i>Add New School</h3>
        <input type="hidden" id="schoolId" />
        <div class="form-group">
            <label>School Name <span style="color:var(--red)">*</span></label>
            <input type="text" id="fSchoolName" placeholder="e.g. Holy Spirit Elementary School" />
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>District</label>
                <input type="text" id="fDistrict" placeholder="e.g. District 2" />
            </div>
            <div class="form-group">
                <label>Address</label>
                <input type="text" id="fAddress" placeholder="Street / Barangay" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>City <span style="color:var(--red)">*</span></label>
                <input type="text" id="fCity" placeholder="e.g. Quezon City" />
            </div>
            <div class="form-group">
                <label>Province</label>
                <input type="text" id="fProvince" placeholder="e.g. Metro Manila" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeSchoolModal()">Cancel</button>
            <button class="btn-save" id="btnSaveSchool" onclick="saveSchool()">
                <i class="fas fa-save me-1"></i>Save School
            </button>
        </div>
    </div>
</div>

<!-- Actions dropdown -->
<div class="dd-actions" id="ddActions">
    <a href="#" id="ddEdit"><i class="fas fa-edit"></i> Edit</a>
    <a href="#" id="ddDelete" class="danger"><i class="fas fa-trash"></i> Delete</a>
</div>

@section scripts {
<script>
(function () {
    var SCHOOLS  = @Html.Raw(ViewBag.SchoolsJson  ?? "[]");
    var STUDENTS = @Html.Raw(ViewBag.StudentsJson ?? "[]");
    var TOTAL    = STUDENTS.length || @(ViewBag.TotalStudents ?? 0);

    var sortField = 'school_name', sortAsc = true;
    var activeId  = null;

    // Enrich with student count + pct
    var data = SCHOOLS.map(function(sc) {
        var name  = sc.school_name || '';
        var count = STUDENTS.filter(function(s) { return (s.school_name || '') === name; }).length;
        return Object.assign({}, sc, {
            _count: count,
            _pct:   TOTAL > 0 ? Math.round(count / TOTAL * 1000) / 10 : 0
        });
    });

    // Populate filter dropdowns
    function unique(arr) { return [...new Set(arr.filter(Boolean))].sort(); }
    unique(data.map(function(sc) { return sc.district || ''; })).forEach(function(v) {
        var o = new Option(v, v); document.getElementById('districtFilter').appendChild(o);
    });
    unique(data.map(function(sc) { return sc.city || ''; })).forEach(function(v) {
        var o = new Option(v, v); document.getElementById('cityFilter').appendChild(o);
    });

    // Sort
    window.sortBy = function(field) {
        if (sortField === field) sortAsc = !sortAsc; else { sortField = field; sortAsc = true; }
        ['school_name','district','city','province','pct'].forEach(function(f) {
            var el = document.getElementById('srt_' + f); if (el) el.textContent = '';
        });
        var el = document.getElementById('srt_' + field);
        if (el) el.textContent = sortAsc ? ' ▲' : ' ▼';
        filterSchools();
    };

    // Filter + render
    window.filterSchools = function() {
        var q  = (document.getElementById('searchInput').value || '').toLowerCase();
        var dt = document.getElementById('districtFilter').value;
        var ct = document.getElementById('cityFilter').value;
        var filtered = data.filter(function(sc) {
            var nm = (sc.school_name || '').toLowerCase();
            return (!q  || nm.includes(q)) &&
                   (!dt || (sc.district || '') === dt) &&
                   (!ct || (sc.city     || '') === ct);
        });
        filtered.sort(function(a, b) {
            var va = sortField === 'pct' ? a._pct : (a[sortField] || '');
            var vb = sortField === 'pct' ? b._pct : (b[sortField] || '');
            if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
            return sortAsc ? va - vb : vb - va;
        });
        renderTable(filtered);
    };

    function esc(v) { return String(v == null ? '' : v).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function renderTable(list) {
        var tbody = document.getElementById('schoolsTbody');
        if (!list.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No schools found.</td></tr>';
            return;
        }
        var html = '';
        list.forEach(function(sc) {
            var id  = sc.school_id || '';
            var pct = sc._pct || 0;
            html += '<tr>' +
                '<td><span class="school-name">' + esc(sc.school_name || '—') + '</span></td>' +
                '<td><span class="district-badge">' + esc(sc.district  || '—') + '</span></td>' +
                '<td>' + esc(sc.city     || '—') + '</td>' +
                '<td>' + esc(sc.province || '—') + '</td>' +
                '<td><div class="pct-bar-wrap">' +
                    '<div class="pct-bar-track"><div class="pct-bar-fill" style="width:' + Math.min(pct,100) + '%"></div></div>' +
                    '<span>' + pct.toFixed(1) + '%</span>' +
                '</div></td>' +
                '<td><button class="actions-btn" onclick="toggleMenu(event,' + JSON.stringify(id) + ')">&#8942;</button></td>' +
                '</tr>';
        });
        tbody.innerHTML = html;
    }

    // Actions dropdown
    window.toggleMenu = function(e, id) {
        e.stopPropagation();
        var menu = document.getElementById('ddActions');
        if (activeId === id && menu.classList.contains('open')) {
            menu.classList.remove('open'); activeId = null; return;
        }
        activeId = id;
        var r = e.currentTarget.getBoundingClientRect();
        menu.style.top  = (r.bottom + 4) + 'px';
        menu.style.left = (r.left - 80) + 'px';
        menu.classList.add('open');
        var sc = data.find(function(s) { return String(s.school_id) === String(id); });
        document.getElementById('ddEdit').onclick = function(ev) {
            ev.preventDefault(); menu.classList.remove('open'); activeId = null;
            if (sc) openEditModal(sc);
        };
        document.getElementById('ddDelete').onclick = function(ev) {
            ev.preventDefault(); menu.classList.remove('open'); activeId = null;
            deleteSchool(id, sc ? sc.school_name : '');
        };
    };
    document.addEventListener('click', function() {
        document.getElementById('ddActions').classList.remove('open'); activeId = null;
    });

    // Modal
    window.openSchoolModal = function() {
        clearForm();
        document.getElementById('modalTitle').innerHTML = '<i class="fas fa-school me-2 text-success"></i>Add New School';
        document.getElementById('schoolModal').classList.add('open');
    };
    window.closeSchoolModal = function() {
        document.getElementById('schoolModal').classList.remove('open');
    };
    function openEditModal(sc) {
        document.getElementById('schoolId').value   = sc.school_id || '';
        document.getElementById('fSchoolName').value= sc.school_name || '';
        document.getElementById('fDistrict').value  = sc.district  || '';
        document.getElementById('fAddress').value   = sc.address   || '';
        document.getElementById('fCity').value      = sc.city      || '';
        document.getElementById('fProvince').value  = sc.province  || '';
        document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit me-2 text-success"></i>Edit School';
        document.getElementById('schoolModal').classList.add('open');
    }
    function clearForm() {
        ['schoolId','fSchoolName','fDistrict','fAddress','fCity','fProvince'].forEach(function(id) {
            document.getElementById(id).value = '';
        });
    }

    // Save
    window.saveSchool = async function() {
        var id       = document.getElementById('schoolId').value.trim();
        var name     = document.getElementById('fSchoolName').value.trim();
        var district = document.getElementById('fDistrict').value.trim();
        var address  = document.getElementById('fAddress').value.trim();
        var city     = document.getElementById('fCity').value.trim();
        var province = document.getElementById('fProvince').value.trim();

        if (!name) { alert('School name is required.'); return; }
        if (!city) { alert('City is required.'); return; }

        var btn = document.getElementById('btnSaveSchool');
        btn.disabled = true; btn.textContent = 'Saving…';

        try {
            var url = id ? '/Schools/UpdateSchool' : '/Schools/CreateSchool';
            var res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ SchoolId: parseInt(id)||0, SchoolName: name, District: district, Address: address, City: city, Province: province })
            });
            var d = await res.json();
            if (d && d.success === false) throw new Error(d.error || 'Save failed.');
            closeSchoolModal();
            location.reload();
        } catch (err) {
            alert('Failed to save school: ' + err.message);
            btn.disabled = false; btn.innerHTML = '<i class="fas fa-save me-1"></i>Save School';
        }
    };

    // Delete
    async function deleteSchool(id, name) {
        if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
        try {
            var res = await fetch('/Schools/DeleteSchool', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ id: parseInt(id) })
            });
            var d = await res.json();
            if (d && d.success === false) throw new Error(d.error || 'Delete failed.');
            location.reload();
        } catch (err) { alert('Failed to delete school: ' + err.message); }
    }

    window.resetFilters = function() {
        document.getElementById('districtFilter').value = '';
        document.getElementById('cityFilter').value     = '';
        document.getElementById('searchInput').value    = '';
        filterSchools();
    };

    filterSchools();
})();
</script>
}
