@inherits System.Web.Mvc.WebViewPage
@using System.Web.Optimization
@{
    ViewBag.Title = "Administration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Styles.Render("~/Content/AdministrationStyles.css")

<div class="admin-accounts-page">

    <!-- ══════════════════════════════════════════════════════════════════
         PAGE HEADER
    ══════════════════════════════════════════════════════════════════ -->
    <div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h2 class="mb-1"><i class="fas fa-user-shield me-2 text-success"></i>Administration</h2>
            <p class="page-subtitle mb-0">Manage administrator and teacher accounts</p>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         STATS ROW — 3 summary cards
    ══════════════════════════════════════════════════════════════════ -->
    <div class="summary-cards" style="grid-template-columns: repeat(3, 1fr);">

        <div class="summary-card">
            <div class="card-icon blue">
                <i class="fas fa-user-tie" style="color:#1d4ed8;"></i>
            </div>
            <div class="card-body">
                <div class="value" id="statTotalAdmins">—</div>
                <div class="label">Total Admins</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="card-icon green">
                <i class="fas fa-chalkboard-teacher" style="color:#15803d;"></i>
            </div>
            <div class="card-body">
                <div class="value" id="statTotalTeachers">—</div>
                <div class="label">Total Teachers</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="card-icon yellow">
                <i class="fas fa-check-circle" style="color:#a16207;"></i>
            </div>
            <div class="card-body">
                <div class="value" id="statActiveAccounts">—</div>
                <div class="label">Active Accounts</div>
            </div>
        </div>

    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         ACCOUNTS PANEL
    ══════════════════════════════════════════════════════════════════ -->
    <div class="accounts-panel">

        <!-- ── Toolbar ──────────────────────────────────────────────── -->
        <div class="panel-toolbar">
            <h3><i class="fas fa-users me-2 text-secondary"></i>Accounts</h3>

            <div class="toolbar-filters flex-wrap">
                <button class="btn-add-account" onclick="openAddAdmin()">
                    <i class="fas fa-plus"></i> Add Account
                </button>

                <input type="text"
                       id="adminSearch"
                       placeholder="Search name or email…"
                       oninput="filterAdmins()"
                       style="min-width:200px;" />

                <select id="adminRoleFilter" onchange="filterAdmins()">
                    <option value="">All Roles</option>
                    <option value="Admin">Admin</option>
                    <option value="Teacher">Teacher</option>
                </select>

                <select id="statusFilter" onchange="filterAdmins()">
                    <option value="">All Statuses</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>

        <!-- ── Accounts Table ───────────────────────────────────────── -->
        <div class="accounts-table-wrapper">
            <table class="accounts-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>School</th>
                        <th>Last Login</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="adminsTableBody">
                    <tr>
                        <td colspan="7" class="text-center py-4" style="color:#9ca3af;">
                            <i class="fas fa-spinner fa-spin me-2"></i>Loading accounts…
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- ── Pagination ────────────────────────────────────────────── -->
        <div class="pagination-row">
            <span id="paginationInfo" style="font-size:13px;color:#6c757d;">Loading…</span>
            <div class="pagination-btns" id="paginationBtns"></div>
        </div>

    </div><!-- /.accounts-panel -->

</div><!-- /.admin-accounts-page -->

<!-- ══════════════════════════════════════════════════════════════════
     MODAL 1 — Add / Edit Account
══════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="adminModal" tabindex="-1" aria-labelledby="adminModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="adminModalLabel">
                    <i class="fas fa-user-plus me-2 text-success"></i>
                    <span id="adminModalTitleText">Add Account</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <!-- Hidden id for edit mode -->
                <input type="hidden" id="aId" value="" />

                <div class="mb-3">
                    <label for="aName" class="form-label fw-semibold" style="font-size:13px;">
                        Full Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="aName" class="form-control form-control-sm"
                           placeholder="Enter full name" />
                    <div class="invalid-feedback" id="aNameError"></div>
                </div>

                <div class="mb-3">
                    <label for="aEmail" class="form-label fw-semibold" style="font-size:13px;">
                        Email Address <span class="text-danger">*</span>
                    </label>
                    <input type="email" id="aEmail" class="form-control form-control-sm"
                           placeholder="Enter email address" />
                    <div class="invalid-feedback" id="aEmailError"></div>
                </div>

                <div class="mb-3">
                    <label for="aPassword" class="form-label fw-semibold" style="font-size:13px;">
                        Password
                    </label>
                    <div class="input-group input-group-sm">
                        <input type="password" id="aPassword" class="form-control"
                               placeholder="Leave blank to keep existing" />
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="togglePasswordVisibility()"
                                title="Show / hide password">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <div class="form-text" style="font-size:11px;">
                        Minimum 8 characters. Leave blank when editing to keep the current password.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="aRole" class="form-label fw-semibold" style="font-size:13px;">
                        Role <span class="text-danger">*</span>
                    </label>
                    <select id="aRole" class="form-select form-select-sm" onchange="onRoleChange()">
                        <option value="">— Select role —</option>
                        <option value="Admin">Admin</option>
                        <option value="Teacher">Teacher</option>
                    </select>
                    <div class="invalid-feedback" id="aRoleError"></div>
                </div>

                <!-- School dropdown — shown only when Role = Teacher -->
                <div class="mb-3" id="schoolFieldWrapper" style="display:none;">
                    <label for="aSchool" class="form-label fw-semibold" style="font-size:13px;">
                        Assigned School <span class="text-danger">*</span>
                    </label>
                    <select id="aSchool" class="form-select form-select-sm">
                        <option value="">— Select school —</option>
                    </select>
                    <div class="invalid-feedback" id="aSchoolError"></div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-success btn-sm" onclick="saveAdmin()" id="btnSaveAdmin"
                        style="background:#11B067;border-color:#11B067;min-width:100px;">
                    <i class="fas fa-save me-1"></i>Save Account
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     TOAST CONTAINER
══════════════════════════════════════════════════════════════════ -->
<div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer" style="z-index:9999;"></div>

@Scripts.Render("~/Scripts/AdministrationScript.js")
